  updatedAt DateTime @updatedAt

  diagnostics    Diagnostic[]
  kpiSnapshots   TransformKPISnapshot[]
  dealRecords    DealRecord[]
  exitDossier    ExitDossier?
  contactLog     HospitalContactLog[]

  @@index([pipelineStage])
  @@index([distressTier])
}

model HospitalContactLog {
  id         String   @id @default(cuid())
  hospitalId String
  hospital   Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  contactedBy String
  channel    String   // CALL | MEETING | EMAIL | VISIT | WHATSAPP
  summary    String   @db.Text
  nextAction String?
  contactedAt DateTime @default(now())

  @@index([hospitalId, contactedAt])
}

model DealRecord {
  id             String   @id @default(cuid())
  hospitalId     String
  hospital       Hospital @relation(fields: [hospitalId], references: [id])
  engagementId   String?
  version        Int      @default(1)

  // Structure
  structureType  String   // SWEAT | CAPITAL | HYBRID
  recommendedByWizard Boolean @default(false)

  // Valuation
  entryValuation  Decimal? @db.Decimal(14, 2)
  exitValBase     Decimal? @db.Decimal(14, 2)
  exitValBear     Decimal? @db.Decimal(14, 2)
  exitValBull     Decimal? @db.Decimal(14, 2)
  exitMultipleBase Decimal? @db.Decimal(5, 2)

  // Equity terms
  cfaEquityPct    Decimal? @db.Decimal(5, 2)
  kickerPct       Decimal? @db.Decimal(5, 2)
  kickerTrigger   String?
  vestCliffMonths Int?
  vestMonthlyPct  Decimal? @db.Decimal(5, 2)
  antiDilution    Boolean  @default(true)

  // Cash terms (Hybrid)
  cashFeeMonthly  Decimal? @db.Decimal(14, 2)
  cashFeePct      Decimal? @db.Decimal(5, 2)

  // Returns (calculated)
  irrBase         Decimal? @db.Decimal(6, 2)
  irrBear         Decimal? @db.Decimal(6, 2)
  irrBull         Decimal? @db.Decimal(6, 2)
  moicBase        Decimal? @db.Decimal(5, 2)
  moicBear        Decimal? @db.Decimal(5, 2)
  moicBull        Decimal? @db.Decimal(5, 2)

  // RTO overlay
  rtoType         String?  // FACILITY | EQUIPMENT | CONCESSION | NONE
  rtoTermsJson    Json?

  // Status
  status          String   @default("MODELLING")
  // MODELLING | PRESENTED | NEGOTIATING | AGREED | ABANDONED
  termSheetUrl    String?
  termSheetVersion Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([hospitalId])
  @@index([engagementId])
}

model Diagnostic {
  id           String   @id @default(cuid())
  hospitalId   String
  hospital     Hospital @relation(fields: [hospitalId], references: [id])
  engagementId String

  // 48-point audit (6 domains, JSON scores)
  clinicalJson    Json?
  operationalJson Json?
  revenueJson     Json?
  financialJson   Json?
  hrJson          Json?
  governanceJson  Json?

  // 22 KPI baseline (immutable once locked)
  revenueMonthly       Decimal? @db.Decimal(14, 2)
  revenuePerBedDay     Decimal? @db.Decimal(14, 2)
  revenuePerOpd        Decimal? @db.Decimal(14, 2)
  ebitdaMarginPct      Decimal? @db.Decimal(5, 2)
  grossMarginPct       Decimal? @db.Decimal(5, 2)
  costPerPatient       Decimal? @db.Decimal(14, 2)
  bedOccupancyPct      Decimal? @db.Decimal(5, 2)
  opdVolumeDaily       Decimal? @db.Decimal(8, 2)
  theatreUtilisationPct Decimal? @db.Decimal(5, 2)
  alosDays             Decimal? @db.Decimal(5, 2)
  hmoDenialRatePct     Decimal? @db.Decimal(5, 2)
  arDays               Decimal? @db.Decimal(8, 2)
  hmoPanelsCount       Int?
  cleanClaimRatePct    Decimal? @db.Decimal(5, 2)
  collectionRatePct    Decimal? @db.Decimal(5, 2)
  staffTurnoverPct     Decimal? @db.Decimal(5, 2)
  doctorBedRatio       Decimal? @db.Decimal(5, 2)
  nurseBedRatio        Decimal? @db.Decimal(5, 2)
  vacancyRatePct       Decimal? @db.Decimal(5, 2)
  readmissionRatePct   Decimal? @db.Decimal(5, 2)
  complaintRate        Decimal? @db.Decimal(8, 2)
  infectionRatePct     Decimal? @db.Decimal(5, 2)

  // Quick wins
  quickWinsJson  Json?

  // 90-day plan
  planDay1to30   Json?
  planDay31to60  Json?
  planDay61to90  Json?

  locked     Boolean   @default(false)
  lockedBy   String?
  lockedAt   DateTime?

  createdAt  DateTime  @default(now())

  @@index([hospitalId])
  @@index([engagementId])
}

model TransformKPISnapshot {
  id           String   @id @default(cuid())
  hospitalId   String
  hospital     Hospital @relation(fields: [hospitalId], references: [id])
  engagementId String
  period       String   // "2024-01" format

  // All 22 KPIs (same fields as Diagnostic baseline)
  revenueMonthly       Decimal? @db.Decimal(14, 2)
  revenuePerBedDay     Decimal? @db.Decimal(14, 2)
  ebitdaMarginPct      Decimal? @db.Decimal(5, 2)
  bedOccupancyPct      Decimal? @db.Decimal(5, 2)
  opdVolumeDaily       Decimal? @db.Decimal(8, 2)
  hmoDenialRatePct     Decimal? @db.Decimal(5, 2)
  arDays               Decimal? @db.Decimal(8, 2)
  hmoPanelsCount       Int?
  cleanClaimRatePct    Decimal? @db.Decimal(5, 2)
  collectionRatePct    Decimal? @db.Decimal(5, 2)
  staffTurnoverPct     Decimal? @db.Decimal(5, 2)
  doctorBedRatio       Decimal? @db.Decimal(5, 2)
  nurseBedRatio        Decimal? @db.Decimal(5, 2)
  readmissionRatePct   Decimal? @db.Decimal(5, 2)

  // RAG summary
  redCount      Int?
  amberCount    Int?
  greenCount    Int?
  vsBaselineJson Json? // Delta for each KPI vs locked diagnostic baseline

  enteredBy  String
  notes      String?  @db.Text
  boardPackIncluded Boolean @default(false)
  createdAt  DateTime @default(now())

  @@unique([hospitalId, engagementId, period])
  @@index([engagementId, period])
}

model ConsultantActivityLog {
  id           String   @id @default(cuid())
  engagementId String
  memberId     String
  date         DateTime
  activity     String   // ON_SITE_VISIT | MEETING | REPORT | DECISION | INTERVENTION
  description  String   @db.Text
  hours        Decimal? @db.Decimal(5, 2)
  immutable    Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@index([engagementId, date])
}

model GovernanceAlert {
  id           String   @id @default(cuid())
  engagementId String
  hospitalId   String
  alertType    String   // STEP_IN_RIGHTS | EXPENDITURE | KPI_KICKER | EXIT_TIMELINE
  triggeredAt  DateTime @default(now())
  status       String   @default("OPEN") // OPEN | ACKNOWLEDGED | RESOLVED
  detailsJson  Json
  resolvedBy   String?
  resolvedAt   DateTime?

  @@index([engagementId, status])
  @@index([alertType, status])
}

model ExitDossier {
  id           String   @id @default(cuid())
  hospitalId   String   @unique
  hospital     Hospital @relation(fields: [hospitalId], references: [id])
  engagementId String

  // Exit valuation
  exitEbitda          Decimal? @db.Decimal(14, 2)
  exitMultipleApplied Decimal? @db.Decimal(5, 2)
  exitValuation       Decimal? @db.Decimal(14, 2)
  exitValRangeLow     Decimal? @db.Decimal(14, 2)
  exitValRangeHigh    Decimal? @db.Decimal(14, 2)

  // Data room
  dataRoomCompletenessPct Int?
  documentsJson    Json?  // 45-item checklist with upload status

  // Buyer pipeline
  buyersJson       Json?  // Array of {name, type, status, cfaWarmth, ticketRange}

  // IM
  imVersion        Int?
  imUrl            String?

  // Process
  ndaLogJson       Json?  // {buyer, signedAt, accessTier}
  ioiLogJson       Json?  // Indicative offers received
  preferredBidder  String?

  // Realised return (on close)
  equityProceeds        Decimal? @db.Decimal(14, 2)
  managementFeesTotal   Decimal? @db.Decimal(14, 2)
  totalCfaReturn        Decimal? @db.Decimal(14, 2)
  realisedMoic          Decimal? @db.Decimal(5, 2)
  realisedIrr           Decimal? @db.Decimal(6, 2)

  status    String @default("NOT_STARTED")
  // NOT_STARTED | PREPARATION | ACTIVE_PROCESS | CLOSED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([engagementId])
}

// ─── PlaybookOS ────────────────────────────────────────────────────────────────

model LibraryAsset {
