// ─── Methodology Framework Library ────────────────────────────────────────────

enum FrameworkStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

model MethodologyTemplate {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String   @db.Text
  category    String   // e.g. "Operations", "Lean", "Quality", "Revenue"
  serviceTypes String[] // which ServiceType values this applies to
  estimatedWeeks Int   @default(8)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  phases      MethodologyPhaseTemplate[]
  engagements Engagement[]               @relation("EngagementMethodology")

  @@index([category])
  @@index([isActive])
}

model MethodologyPhaseTemplate {
  id               String              @id @default(cuid())
  methodologyId    String
  methodology      MethodologyTemplate @relation(fields: [methodologyId], references: [id], onDelete: Cascade)
  name             String
  description      String?             @db.Text
  order            Int
  typicalWeeks     Int                 @default(2)
  keyActivities    String[]
  keyDeliverables  String[]
  createdAt        DateTime            @default(now())

  gates            GateTemplate[]

  @@index([methodologyId, order])
}

model GateTemplate {
  id        String                   @id @default(cuid())
  phaseId   String
  phase     MethodologyPhaseTemplate @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  name      String
  criteria  String                   @db.Text
  order     Int                      @default(0)
  createdAt DateTime                 @default(now())

  @@index([phaseId])
}

model FrameworkTemplate {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String   @db.Text
  category    String   // "Strategic Analysis", "Operational", "Financial", "Stakeholder", etc.
  dimensions  String[] // the axes/sections of this framework
  guideText   String?  @db.Text
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  engagementFrameworks EngagementFramework[]

  @@index([category])
  @@index([isActive])
}

model EngagementFramework {
  id          String            @id @default(cuid())
  engagementId String           @map("projectId")
  engagement   Engagement       @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  frameworkId String
  framework   FrameworkTemplate @relation(fields: [frameworkId], references: [id])
  content     Json              // AI-generated or consultant-filled content keyed by dimension
  aiGenerated Boolean           @default(false)
  status      FrameworkStatus   @default(DRAFT)
  notes       String?           @db.Text
  createdById String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@map("ProjectFramework")
  @@unique([engagementId, frameworkId], map: "ProjectFramework_projectId_frameworkId_key")
  @@index([engagementId], map: "ProjectFramework_projectId_idx")
}

// ─── Training & Certification Academy ─────────────────────────────────────────

enum TrainingLevel {
  FOUNDATION
  SPECIALIST
  MASTER
}

enum TrainingModuleStatus {
  LOCKED
  AVAILABLE
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum CertificationStatus {
  NOT_STARTED
  IN_PROGRESS
  EXAM_SCHEDULED
  CERTIFIED
  EXPIRED
  REVOKED
}

enum QuestionType {
  MULTIPLE_CHOICE
  MULTI_SELECT
  CASE_STUDY
  SHORT_ANSWER
}

model TrainingTrack {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String   @db.Text
  level       TrainingLevel
  category    String   // "methodology", "health_economics", "public_health", "tech", "leadership"
  iconName    String?  // lucide icon name
  colorHex    String?  // badge color
  prerequisites String[] // slugs of prerequisite tracks
  estimatedHours Int   @default(20)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)

  // Pricing
  pricingType TrackPricingType @default(FREE)
  priceNGN    Decimal?         @db.Decimal(10, 2)
  discountPct Decimal?         @db.Decimal(5, 2) // e.g. 10.00 = 10% off for academy learners

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  modules     TrainingModule[]
  enrollments TrainingEnrollment[]
  purchases   TrackPurchase[]

  @@index([category, level])
  @@index([isActive])
}

model TrainingModule {
  id          String   @id @default(cuid())
  trackId     String
  track       TrainingTrack @relation(fields: [trackId], references: [id], onDelete: Cascade)
  name        String
  slug        String   @unique
  description String   @db.Text
  order       Int
  estimatedMinutes Int @default(60)
  content     Json     // structured content: sections, text, examples, exercises
  videoUrl    String?
  resources   Json?    // { links: [], files: [], tools: [] }
  passingScore Int     @default(70) // percentage
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  progress    ModuleProgress[]
  questions   TrainingQuestion[]

  @@index([trackId, order])
}

model TrainingQuestion {
  id          String       @id @default(cuid())
  moduleId    String
  module      TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  type        QuestionType @default(MULTIPLE_CHOICE)
  question    String       @db.Text
  options     Json?        // for multiple choice: [{ id, text, isCorrect }]
  correctAnswer String?    @db.Text // for short answer
  explanation String?      @db.Text // shown after answering
  points      Int          @default(1)
  order       Int          @default(0)
  caseStudy   Json?        // { scenario, data, exhibits } for case study questions
  createdAt   DateTime     @default(now())

  answers     QuestionAnswer[]

  @@index([moduleId, order])
}

model TrainingEnrollment {
  id          String              @id @default(cuid())
  userId      String
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  trackId     String
  track       TrainingTrack       @relation(fields: [trackId], references: [id], onDelete: Cascade)
  status      CertificationStatus @default(NOT_STARTED)
  enrolledAt  DateTime            @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  certifiedAt DateTime?
  expiresAt   DateTime?           // certifications expire after 2 years
  overallScore Int?               // final assessment score
  certificateUrl String?          // generated PDF certificate

  moduleProgress ModuleProgress[]

  @@unique([userId, trackId])
  @@index([userId, status])
  @@index([trackId])
}

model ModuleProgress {
  id           String               @id @default(cuid())
  enrollmentId String
  enrollment   TrainingEnrollment   @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  moduleId     String
  module       TrainingModule       @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  status       TrainingModuleStatus @default(LOCKED)
  startedAt    DateTime?
  completedAt  DateTime?
  score        Int?                 // quiz score percentage
