  startedAt       DateTime?
  completedAt     DateTime?
  expiresAt       DateTime                    // 48hr window

  // Integrity signals
  tabSwitchCount    Int     @default(0)
  pasteEventCount   Int     @default(0)
  suspiciousFlags   Json?   // detailed integrity data

  // AI scoring
  aiContentScore    Int?    // 0-100 quality of answers
  aiIntegrityScore  Int?    // 0-100 authenticity assessment
  aiBreakdown       Json?   // detailed scoring per section

  // Video
  videoUrl          String?
  videoDurationSec  Int?

  // Admin review
  adminScore        Int?
  adminTier         String? // STANDARD, SENIOR, PRINCIPAL
  adminNotes        String? @db.Text
  reviewedById      String?
  reviewedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  responses ConsultantAssessmentResponse[]

  @@index([userId, status])
}

model ConsultantAssessmentResponse {
  id            String                @id @default(cuid())
  assessmentId  String
  assessment    ConsultantAssessment  @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  part          String                // "scenario", "experience", "quickfire", "video"
  questionId    String                // reference to question
  questionText  String    @db.Text
  answer        String    @db.Text

  // Integrity per response
  timeSpentSec    Int?
  pasteEvents     Int     @default(0)
  tabSwitches     Int     @default(0)
  typingPattern   Json?   // keystroke timing data
  wordCount       Int?

  answeredAt DateTime @default(now())

  @@index([assessmentId])
}

// ─── Consultant Onboarding ──────────────────────────────────────────────────

enum OnboardingStatus {
  INVITED
  PROFILE_SETUP
  ASSESSMENT_PENDING
  ASSESSMENT_COMPLETE
  REVIEW
  ACTIVE
  REJECTED
}

model ConsultantOnboarding {
  id                  String           @id @default(cuid())
  userId              String           @unique
  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  status              OnboardingStatus @default(INVITED)
  assessmentLevel     String           @default("STANDARD") // LIGHT, STANDARD, FULL
  profileCompleted    Boolean          @default(false)
  assessmentCompleted Boolean          @default(false)
  reviewedById        String?
  reviewNotes         String?          @db.Text
  approvedAt          DateTime?
  applicationId       String?          // link back to TalentApplication if came from public apply
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([status])
}
