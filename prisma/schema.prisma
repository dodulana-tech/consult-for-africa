// ─── Staffing & Opportunity Board ─────────────────────────────────────────────

model StaffingRequest {
  id          String     @id @default(cuid())
  engagementId String    @map("projectId")
  engagement   Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  createdById String?
  createdBy   User?    @relation("StaffingRequestCreator", fields: [createdById], references: [id], onDelete: SetNull)
  trackId     String?
  track       EngagementTrack? @relation(fields: [trackId], references: [id])

  role              String           // "Lead Consultant", "Analyst", etc.
  description       String  @db.Text // what the work involves
  skillsRequired    String[]         // e.g. ["turnaround", "revenue-cycle", "digital-health"]
  hoursPerWeek      Int              // expected weekly commitment
  duration          String?          // "8 weeks", "3 months", etc.
  rateType          RateType
