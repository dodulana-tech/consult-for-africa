  // Conversion tracking
  convertedToClientId String?
  convertedToClient   Client? @relation(fields: [convertedToClientId], references: [id])
  proposalId          String?
  leadId              String?
  lead                Lead?   @relation(fields: [leadId], references: [id])

  // Meta
  conductedById      String?
  conductedBy        User?   @relation(fields: [conductedById], references: [id], onDelete: SetNull)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Meeting
  meetingId          String?  @unique
  meeting            Meeting? @relation(fields: [meetingId], references: [id])

  // Communications CRM back-relations
  communications     Communication[]

  @@index([conductedById])
  @@index([status])
}

// ─── Meetings & Video Calls ─────────────────────────────────────────────────

enum MeetingStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum MeetingType {
  DISCOVERY_CALL
  PROJECT_CHECKIN
  INTERNAL
  CLIENT_REVIEW
  COACHING
}

model Meeting {
  id              String        @id @default(cuid())
  title           String
  description     String?       @db.Text
  type            MeetingType
  status          MeetingStatus @default(SCHEDULED)

  // Schedule
  scheduledAt     DateTime
  scheduledEndAt  DateTime
  startedAt       DateTime?
  endedAt         DateTime?
  duration        Int?          // actual duration in minutes

  // Google Meet
  meetLink        String?       // Google Meet URL
  calendarEventId String?       // Google Calendar event ID for sync

  // Participants
  organizerId     String?
  organizer       User?         @relation("MeetingOrganizer", fields: [organizerId], references: [id], onDelete: SetNull)
  participants    MeetingParticipant[]

  // Links to other entities
  engagementId    String?
  engagement      Engagement?   @relation(fields: [engagementId], references: [id])
  discoveryCall   DiscoveryCall?
  clientId        String?

  // Nuru bot
  nuruEnabled     Boolean       @default(true)
  nuruJoined      Boolean       @default(false)

  // Transcript & Notes
  transcript      String?       @db.Text
  aiSummary       String?       @db.Text
  aiActionItems   String[]
  aiKeyDecisions  String[]

  // Recording
  recordingUrl    String?
  recordingBucket String?
  recordingKey    String?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([organizerId])
  @@index([scheduledAt])
  @@index([status])
  @@index([engagementId])
}

model MeetingParticipant {
  id          String   @id @default(cuid())
  meetingId   String
  meeting     Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  // Internal user (optional - external participants won't have this)
  userId      String?
  user        User?    @relation("MeetingParticipants", fields: [userId], references: [id], onDelete: SetNull)

  // External participant info
  name        String
  email       String
  role        String?  // e.g. "Client", "Consultant", "Stakeholder"

  // Attendance
  attended    Boolean  @default(false)
  joinedAt    DateTime?
  leftAt      DateTime?

  createdAt   DateTime @default(now())

  @@unique([meetingId, email])
  @@index([meetingId])
  @@index([userId])
}

// ─── NDA & Legal Documents ───────────────────────────────────────────────────

enum NdaType {
  MUTUAL_CLIENT          // Standard Mutual NDA (your v1.0 template)
  CONSULTANT_MASTER      // One-time NDA for consultants joining C4A
  PROJECT_SPECIFIC       // Extra NDA for sensitive engagements (M&A, etc.)
}

enum NdaStatus {
  DRAFT                  // Generated, not yet sent
  PENDING_PARTY_A        // Awaiting Party A signature
  PENDING_PARTY_B        // Awaiting Party B (C4A countersign)
  ACTIVE                 // Fully executed
  EXPIRED                // Past the 3-year confidentiality period
  TERMINATED             // Manually terminated
}

model Nda {
  id              String    @id @default(cuid())
  type            NdaType
  status          NdaStatus @default(DRAFT)
  version         String    @default("1.0")

  // Party A (Client / Consultant / External)
  partyAName      String
  partyAOrg       String
  partyATitle     String?
  partyAEmail     String
  partyASignature String?   // base64 signature image
  partyASignedAt  DateTime?
  partyAIp        String?   // IP address at time of signing

  // Party B (C4A side)
  partyBName      String    @default("Consult For Africa")
  partyBOrg       String    @default("Consult For Africa")
  partyBTitle     String?
  partyBEmail     String?
  partyBSignature String?
  partyBSignedAt  DateTime?
  partyBIp        String?

  // Schedule
  effectiveDate   DateTime
  expiresAt       DateTime? // auto-calculated: engagement end + 3 years

  // Signed PDF
  signedPdfUrl    String?   // S3 URL of fully-executed PDF
  signedPdfKey    String?   // S3 key for deletion

  // Links
  engagementId    String?
  engagement      Engagement? @relation(fields: [engagementId], references: [id])
  clientId        String?
  client          Client?     @relation(fields: [clientId], references: [id])
  consultantId    String?     // User ID of consultant (for CONSULTANT_MASTER)
  consultant      User?       @relation("ConsultantNdas", fields: [consultantId], references: [id], onDelete: SetNull)

  // Signing token (for email-based signing by external parties)
  signingToken    String?   @unique
  signingTokenExp DateTime?

  // Audit
  createdById     String?
  createdBy       User?     @relation("NdaCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([engagementId])
  @@index([clientId])
  @@index([consultantId])
  @@index([status])
  @@index([signingToken])
}

// ─── Intern & Talent Pipeline ────────────────────────────────────────────────

model InternCohort {
  id          String   @id @default(cuid())
  name        String   // e.g. "SIWES Cohort 1 - Q3 2026"
  track       String   // SIWES, SUMMER, FELLOWSHIP
  startDate   DateTime
  endDate     DateTime
  maxInterns  Int      @default(5)
  status      String   @default("PLANNED") // PLANNED, ACTIVE, COMPLETED
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rotations   InternRotation[]

  @@index([status])
}

model InternRotation {
  id           String       @id @default(cuid())
  cohortId     String
  cohort       InternCohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  internId     String       // User ID of the intern
  intern       User         @relation("InternRotations", fields: [internId], references: [id], onDelete: Cascade)
  engagementId String?      @map("projectId")
  engagement   Engagement?  @relation(fields: [engagementId], references: [id])
  supervisorId String?
  supervisor   User?        @relation("SupervisedRotations", fields: [supervisorId], references: [id], onDelete: SetNull)
  startDate    DateTime
  endDate      DateTime
  status       String       @default("ACTIVE") // ACTIVE, COMPLETED, TERMINATED
  notes        String?      @db.Text
  createdAt    DateTime     @default(now())

  evaluations  InternEvaluation[]

  @@index([internId])
  @@index([cohortId])
}

model InternEvaluation {
  id           String         @id @default(cuid())
  rotationId   String
  rotation     InternRotation @relation(fields: [rotationId], references: [id], onDelete: Cascade)
  evaluatorId  String?
  evaluator    User?          @relation("InternEvaluations", fields: [evaluatorId], references: [id], onDelete: SetNull)
  period       String         // e.g. "Month 1", "Final"

  // Scoring (1-5 each)
  technicalSkills    Int
  communication      Int
  professionalism    Int
  initiative         Int
  teamwork           Int
  overallScore       Int      // calculated average

  strengths          String[]
  areasForDevelopment String[]
  supervisorComments String?  @db.Text
  recommendPromotion Boolean  @default(false) // recommend for EMERGING tier
  createdAt          DateTime @default(now())

  @@index([rotationId])
}

// ─── Outreach Campaigns (Maarova Growth) ─────────────────────────────────────

model OutreachCampaign {
  id          String   @id @default(cuid())
  name        String   // e.g. "March 2026 - Lagos Hospital CEOs"
  description String?  @db.Text
  month       String   // e.g. "2026-03"
  status      String   @default("DRAFT") // DRAFT, ACTIVE, COMPLETED
  targetCount Int      @default(0)
  sentCount   Int      @default(0)
  respondedCount Int   @default(0)
  assessmentCount Int  @default(0) // how many actually took assessment
  createdById String?
  createdBy   User?    @relation("CampaignCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  targets OutreachTarget[]

  @@index([status])
  @@index([month])
}

model OutreachTarget {
  id           String           @id @default(cuid())
  campaignId   String
  campaign     OutreachCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name         String
  title        String?          // e.g. "CEO", "Medical Director"
  organization String?
  email        String?
  phone        String?
  linkedinUrl  String?
  city         String?
  source       String?          // LinkedIn, Conference, Referral, MDCN registry, etc.
  status       String           @default("IDENTIFIED") // IDENTIFIED, INVITED, RESPONDED, ASSESSMENT_STARTED, ASSESSMENT_COMPLETED, DECLINED, NO_RESPONSE
  invitedAt    DateTime?
  respondedAt  DateTime?
  notes        String?          @db.Text
  maarovaUserId String?         // if they completed assessment, link to MaarovaUser
  inviteToken  String?          @unique // token for self-onboarding link
  tokenExpiresAt DateTime?      // token expiry (30 days from invite)
  createdAt    DateTime         @default(now())

  @@index([campaignId, status])
}

// ─── Nuru Pricing Intelligence ───────────────────────────────────────────────

model PricingIntelligence {
  id             String   @id @default(cuid())
  computedAt     DateTime @default(now())
  dataPoints     Int      // how many deliverables/entries were analyzed
  stats          Json     // aggregated stats: avg fee by deliverable type, avg hours, tier distribution
  // Format: { deliverableTypes: [{ name, avgFee, avgHours, count, tiers }], ratesByTier: {...}, clientTypeMultipliers: {...} }
}

// ─── Transform OS ──────────────────────────────────────────────────────────────

model Hospital {
  id                  String   @id @default(cuid())
  name                String
  address             String?
  state               String
  lga                 String?
  bedCount            Int?
  ownershipType       String?  // PRIVATE_SOLO | PRIVATE_GROUP | MISSION | PPP
  specialtyFocus      String?
  hmoPanelsCount      Int?
  nhiaAccredited      Boolean  @default(false)
  registrationNumber  String?

  // Distress scoring (0-100, computed)
  distressScore       Decimal? @db.Decimal(5, 2)
  distressTier        String?  // A | B | C | D
  financialScore      Decimal? @db.Decimal(5, 2)
  operationalScore    Decimal? @db.Decimal(5, 2)
  clinicalScore       Decimal? @db.Decimal(5, 2)
  staffingScore       Decimal? @db.Decimal(5, 2)
  infrastructureScore Decimal? @db.Decimal(5, 2)
  governanceScore     Decimal? @db.Decimal(5, 2)

  // Pipeline CRM
  pipelineStage       String   @default("IDENTIFIED")
  // IDENTIFIED | QUALIFIED | APPROACHED | IN_DIALOGUE | TERM_SHEET | ACTIVE | EXITED | CLOSED
  founderMotivation   String?  // EXIT | TIRED | GROWTH | SUCCESSION
  founderSuccession   Boolean?
  cfaRelationshipScore Int?    // 1-5
  source              String?
  referredBy          String?
  lastContactDate     DateTime?
  nextAction          String?
  nextActionDate      DateTime?
  priorityRank        Int?

