  updatedAt      DateTime @updatedAt

  @@index([status])
}

model PartnerContact {
  id             String   @id @default(cuid())
  partnerId      String
  partner        PartnerFirm @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  name           String
  email          String   @unique
  passwordHash   String?
  title          String?
  phone          String?
  isPrimary      Boolean  @default(false)
  isPortalEnabled Boolean @default(false)
  lastLoginAt    DateTime?
  resetToken       String?
  resetTokenExpiry DateTime?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([partnerId])
}

model PartnerStaffingRequest {
  id             String   @id @default(cuid())
  partnerId      String
  partner        PartnerFirm @relation(fields: [partnerId], references: [id])
  requestCode    String   @unique // PSR-2026-001 format

  // What they need
  projectName    String
  projectDescription String @db.Text
  rolesNeeded    Int      @default(1)
  skillsRequired String[]
  serviceTypes   String[] // maps to C4A ServiceType values
  seniority      String?  // EMERGING | STANDARD | EXPERIENCED | ELITE
  hoursPerWeek   Int?
  startDate      DateTime?
  durationWeeks  Int?

  // Commercial
  clientBudgetPerDay Decimal? @db.Decimal(10, 2) // what partner will pay C4A per day
  budgetCurrency     String   @default("NGN")

  // Workflow
  status         PartnerRequestStatus @default(DRAFT)
  submittedAt    DateTime?
  matchedAt      DateTime?  // when C4A sent shortlist
  confirmedAt    DateTime?  // when partner confirmed selections

  // Internal
  cfaReviewedById String?
  cfaNotes        String?  @db.Text

  deployments    PartnerDeployment[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([partnerId, status])
}

model PartnerDeployment {
  id             String   @id @default(cuid())
  requestId      String
  request        PartnerStaffingRequest @relation(fields: [requestId], references: [id])
  consultantId   String   // User ID of the consultant

  // Assignment terms
  role           String
  ratePerDay     Decimal  @db.Decimal(10, 2) // C4A's rate to consultant
  billingRatePerDay Decimal @db.Decimal(10, 2) // rate charged to partner
  rateCurrency   String   @default("NGN")
  startDate      DateTime?
  endDate        DateTime?
  hoursPerWeek   Int?

  // Anonymised profile (sent to partner before confirmation)
  anonymisedProfile Json?  // {tier, yearsExperience, expertiseAreas, bio snippet}

  // Status
  status         PartnerDeploymentStatus @default(PROPOSED)
  proposedAt     DateTime @default(now())
  acceptedAt     DateTime?
  declinedReason String?
  completedAt    DateTime?

  // Performance
  partnerRating  Int?     // 1-5 rating from partner at end
  partnerFeedback String? @db.Text

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([requestId])
  @@index([consultantId])
  @@index([status])
}

model PartnerInvoice {
  id             String   @id @default(cuid())
  partnerId      String
  partner        PartnerFirm @relation(fields: [partnerId], references: [id])
  invoiceNumber  String   @unique // PC4A-INV-2026-001 format

  // Line items
  lineItems      Json     // [{consultantRole, days, ratePerDay, amount}]
  subtotal       Decimal  @db.Decimal(14, 2)
  tax            Decimal  @default(0) @db.Decimal(14, 2)
  total          Decimal  @db.Decimal(14, 2)
  currency       String   @default("NGN")

  period         String?  // "2026-03" billing period
  status         String   @default("DRAFT") // DRAFT | SENT | PAID | OVERDUE | CANCELLED
  issuedDate     DateTime?
  dueDate        DateTime?
  paidDate       DateTime?
  paymentRef     String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([partnerId])
  @@index([status])
}

// ─── INVOICING & BILLING ─────────────────────────────────────────────────────

model InvoiceLineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Decimal @db.Decimal(10, 2)
  unitPrice   Decimal @db.Decimal(14, 2)
  amount      Decimal @db.Decimal(14, 2)
  sortOrder   Int     @default(0)
  category    String? // consulting_fee, expense_reimbursement, success_fee, mobilization, holdback

  // Links to source data
  timeEntryIds    String[] // TimeEntry IDs used to generate this line
  milestoneId     String?  // Milestone (deliverable-linked)
  paymentMilestoneId String? // PaymentMilestone FK
  paymentMilestone   PaymentMilestone? @relation(fields: [paymentMilestoneId], references: [id])

  createdAt DateTime @default(now())

  @@index([invoiceId])
}

model Payment {
  id              String        @id @default(cuid())
  invoiceId       String
  invoice         Invoice       @relation(fields: [invoiceId], references: [id])
  amount          Decimal       @db.Decimal(14, 2)
  currency        Currency      @default(NGN)
  paymentDate     DateTime
  paymentMethod   String        // bank_transfer, paystack, wise, cheque, cash
  reference       String?       // bank reference or cheque number
  paystackRef     String?       @unique // Paystack transaction reference
  paystackTxnId   String?       // Paystack transaction ID
  bankName        String?
  status          PaymentStatus @default(PENDING)
  notes           String?       @db.Text
  receiptUrl      String?       // generated receipt URL

  confirmedById   String?
  confirmedBy     User?         @relation("PaymentConfirmer", fields: [confirmedById], references: [id], onDelete: SetNull)
  confirmedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([invoiceId])
  @@index([status])
}

model BillingSchedule {
  id              String        @id @default(cuid())
  engagementId    String        @map("projectId")
  engagement      Engagement    @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  feeStructure    FeeStructure
  billingCycle    BillingCycle
  totalContractValue Decimal    @db.Decimal(14, 2)
  currency        Currency      @default(NGN)

  // Mobilization / upfront deposit
  mobilizationPct   Decimal?    @db.Decimal(5, 2) // e.g. 30.00 = 30%
  mobilizationFixed Decimal?    @db.Decimal(14, 2) // or fixed amount

  // Holdback / retention
  holdbackPct     Decimal?      @db.Decimal(5, 2)

  // Success fee
  successFeePct   Decimal?      @db.Decimal(5, 2)
  successFeeTrigger String?     // description of trigger condition

  // Retainer
  retainerAmount  Decimal?      @db.Decimal(14, 2)

  // Terms
  paymentTermsDays Int          @default(30)
  taxRatePct       Decimal      @default(0) @db.Decimal(5, 2) // VAT
  whtRatePct       Decimal      @default(0) @db.Decimal(5, 2) // withholding tax

  notes           String?       @db.Text
  isActive        Boolean       @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices  Invoice[]

  @@index([engagementId], map: "BillingSchedule_projectId_idx")
}

model CreditNote {
  id                String  @id @default(cuid())
  creditNoteNumber  String  @unique // C4A-CN-YYYY-NNNN
  originalInvoiceId String
  originalInvoice   Invoice @relation("CreditNoteOriginal", fields: [originalInvoiceId], references: [id])
  clientId          String
  client            Client  @relation(fields: [clientId], references: [id])
  engagementId      String? @map("projectId")
  engagement        Engagement? @relation(fields: [engagementId], references: [id])

  reason            String  @db.Text
  subtotal          Decimal @db.Decimal(14, 2)
  tax               Decimal @default(0) @db.Decimal(14, 2)
  total             Decimal @db.Decimal(14, 2)
  currency          Currency @default(NGN)
  status            String  @default("DRAFT") // DRAFT, ISSUED, APPLIED

  issuedDate        DateTime?
  appliedToInvoiceId String?
  appliedToInvoice   Invoice? @relation("CreditNoteApplied", fields: [appliedToInvoiceId], references: [id])

  createdById       String?
  createdBy         User?   @relation("CreditNoteCreator", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([originalInvoiceId])
}

model InvoiceReminder {
  id           String   @id @default(cuid())
  invoiceId    String
  invoice      Invoice  @relation(fields: [invoiceId], references: [id])
  sentAt       DateTime @default(now())
  channel      String   @default("EMAIL") // EMAIL, WHATSAPP, SMS
  reminderType String   // FIRST_REMINDER, SECOND_REMINDER, FINAL_NOTICE, ESCALATION
  recipientEmail String
  notes        String?

  createdAt DateTime @default(now())

  @@index([invoiceId])
}

model ExchangeRate {
  id            String   @id @default(cuid())
  fromCurrency  Currency
  toCurrency    Currency
  rate          Decimal  @db.Decimal(12, 6)
  effectiveDate DateTime
  source        String   @default("manual") // manual, api

  createdAt DateTime @default(now())

  @@unique([fromCurrency, toCurrency, effectiveDate])
  @@index([effectiveDate])
}

// ─── CadreHealth: Healthcare Workforce Platform ──────────────────────────────

enum CadreProfessionalCadre {
  MEDICINE
  DENTISTRY
  NURSING
  MIDWIFERY
  PHARMACY
  MEDICAL_LABORATORY_SCIENCE
  RADIOGRAPHY_IMAGING
  REHABILITATION_THERAPY
  OPTOMETRY
  COMMUNITY_HEALTH
  ENVIRONMENTAL_HEALTH
  NUTRITION_DIETETICS
  PSYCHOLOGY_SOCIAL_WORK
  PUBLIC_HEALTH
  HEALTH_RECORDS
  HOSPITAL_MANAGEMENT
  HEALTH_ADMINISTRATION // deprecated - kept for legacy data; do not use in new signups
  BIOMEDICAL_ENGINEERING
}

enum CadreAccountStatus {
  UNVERIFIED       // registered but license not yet verified
  PENDING_REVIEW   // license submitted, awaiting verification
  VERIFIED         // license verified against regulatory body
  SUSPENDED        // account suspended (integrity issue)
  IMPORTED         // imported from external database, not yet claimed
}

enum CadreAvailability {
  ACTIVELY_LOOKING     // open to offers now
  OPEN_TO_OFFERS       // not actively searching but would consider
  DOING_LOCUM          // primarily doing locum/shift work
  NOT_LOOKING          // employed, not interested right now
}

enum CadreOpenTo {
  PERMANENT
  LOCUM
  CONSULTING
  INTERNATIONAL
  SHORT_MISSION
  MEDEVAC
  REMOTE
}

enum CadreVerificationStatus {
  NOT_SUBMITTED
  PENDING
  VERIFIED
  FAILED
  EXPIRED
}

enum CadreFacilityType {
  PUBLIC_TERTIARY         // teaching hospitals, FMCs
  PUBLIC_SECONDARY        // state/general hospitals
  PUBLIC_PRIMARY          // PHCs
  PRIVATE_TERTIARY
  PRIVATE_SECONDARY
  PRIVATE_CLINIC
  FAITH_BASED
  NGO
  MILITARY
  INTERNATIONAL           // NHS, Gulf, etc.
}

enum CadreMandateStatus {
  OPEN
  SOURCING
  SHORTLISTED
  INTERVIEWING
  OFFER_EXTENDED
  PLACED
  CLOSED
  CANCELLED
}

enum CadreMandateType {
  PERMANENT
  LOCUM
  CONTRACT
  CONSULTING
  INTERNATIONAL
}

// ─── CadreHealth: Professional Profile ───

model CadreProfessional {
  id                    String                  @id @default(cuid())
  email                 String                  @unique
  phone                 String?
  passwordHash          String?                 // null for express-apply leads; set on registration
  firstName             String
  lastName              String
  photo                 String?

  // Professional identity
  cadre                 CadreProfessionalCadre
  subSpecialty           String?                // free text within cadre
  yearsOfExperience     Int?
  currentRole           String?
  currentFacility       String?
  currentFacilityId     String?
  currentFacilityRef    CadreFacility?          @relation("CurrentStaff", fields: [currentFacilityId], references: [id])

  // Location
  state                 String?
  city                  String?
  country               String                  @default("Nigeria")
  isDiaspora            Boolean                 @default(false)
  diasporaCountry       String?

  // Status
  accountStatus         CadreAccountStatus      @default(UNVERIFIED)
  availability          CadreAvailability?
  openTo                CadreOpenTo[]
  noticePeriodWeeks     Int?
  availableFrom         DateTime?

  // Salary (for salary map - self-reported, anonymized)
  monthlySalary         Decimal?                @db.Decimal(12, 2)
  salaryCurrency        String?                 @default("NGN")
  salaryReportedAt      DateTime?
  includesAllowances    Boolean?
  locumDailyRate        Decimal?                @db.Decimal(10, 2)

  // Password reset
  passwordResetToken    String?
  passwordResetExpiry   DateTime?

  // Email verification
  emailVerified         Boolean                 @default(false)
  emailVerifyToken      String?
  emailVerifyTokenExpiry DateTime?

  // Referral tracking
  referredById          String?
  referredBy            CadreProfessional?      @relation("Referrals", fields: [referredById], references: [id])
  referrals             CadreProfessional[]     @relation("Referrals")
  referralCode          String?                 @unique

  // Career readiness score (cached from last assessment)
  readinessScoreDomestic Int?
  readinessScoreUK       Int?
  readinessScoreUS       Int?
  readinessScoreCanada   Int?
  readinessScoreGulf     Int?
  readinessComputedAt    DateTime?

  // CV & Summary
  cvFileUrl              String?
  summary                String?                 @db.Text // AI-generated or manual professional summary

  // Document submission
  governmentIdUrl        String?
  passportPhotoUrl       String?
  documentsSubmittedAt   DateTime?               // Set when all required docs uploaded; idempotency flag

  // Recruitment pipeline
  recruitmentStage       String?                 // SCREENING, SHORTLISTED, INTERVIEW_SCHEDULED, INTERVIEW_DONE, OFFER, PLACED, REJECTED
  recruitmentNotes       String?                 @db.Text
  interviewDate          DateTime?

  // Profile completeness
  profileCompleteness    Int                     @default(0) // 0-100

  // Relations
  credentials           CadreCredential[]
  qualifications        CadreQualification[]
  cpdEntries            CadreCPDEntry[]
  workHistory           CadreWorkHistory[]
  facilityReviews       CadreFacilityReview[]
  salaryReports         CadreSalaryReport[]
  mandateMatches        CadreMandateMatch[]
  readinessAssessments  CadreReadinessAssessment[]
  outreachRecord        CadreOutreachRecord?
  whatsAppMessages      CadreWhatsAppMessage[]
  facilityReferrals     CadreFacilityReferral[] @relation("FacilityReferrals")
  careerReports         CadreCareerReport[]
  advisorMessages       CadreAdvisorMessage[]
  mentorProfile         CadreMentorProfile?
  menteeMentorships     CadreMentorship[]       @relation("MenteeMentorships")
  notifications         CadreNotification[]
  subscription          CadreSubscription?
  coachingSessions      CadreCoachingSession[]

  // Profile analytics
  profileViews          Int                     @default(0)
  lastViewedAt          DateTime?

  // Communications CRM back-relations
  communications        Communication[]
  commParticipants      CommunicationParticipant[] @relation("CommParticipantCadrePro")

  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  @@index([cadre])
  @@index([state, city])
  @@index([accountStatus])
  @@index([availability])
  @@index([readinessScoreDomestic])
}

// ─── CadreHealth: Regulatory Credentials ───

model CadreCredential {
  id                    String                  @id @default(cuid())
  professionalId        String
  professional          CadreProfessional       @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  // What credential
  type                  String                  // PRACTICING_LICENSE, FULL_REGISTRATION, COGS, SPECIALIST_REGISTRATION, ADDITIONAL_LICENSE
  regulatoryBody        String                  // MDCN, NMCN, PCN, MLSCN, RRBN, MRTB, ODORBN, CHPRBN, EHORECON, ICNDN, COREN
  licenseNumber         String?
  issuedDate            DateTime?
  expiryDate            DateTime?

  // Verification
  verificationStatus    CadreVerificationStatus @default(NOT_SUBMITTED)
  verifiedAt            DateTime?
  verifiedBy            String?                 // admin user ID who verified
  documentUrl           String?                 // uploaded certificate/license

  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  @@index([professionalId])
  @@index([type, verificationStatus])
  @@index([expiryDate])
}

// ─── CadreHealth: Qualifications ───

model CadreQualification {
  id                    String                  @id @default(cuid())
  professionalId        String
  professional          CadreProfessional       @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  type                  String                  // PRIMARY_DEGREE, POSTGRADUATE, FELLOWSHIP, CERTIFICATION, INTERNATIONAL_EXAM
  name                  String                  // e.g. "MBBS", "FWACP", "ACLS", "PLAB 1", "IELTS"
  institution           String?
  yearObtained          Int?
  score                 String?                 // for exams like IELTS "7.5", PLAB "Pass"
  expiryDate            DateTime?               // for time-limited certs like IELTS, ACLS
  documentUrl           String?
  verificationStatus    CadreVerificationStatus @default(NOT_SUBMITTED)

  createdAt             DateTime                @default(now())

  @@index([professionalId])
  @@index([type])
}

// ─── CadreHealth: CPD Tracker ───

model CadreCPDEntry {
  id                    String                  @id @default(cuid())
  professionalId        String
  professional          CadreProfessional       @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  activity              String                  // description of CPD activity
  category              String                  // CONFERENCE, WORKSHOP, ONLINE_COURSE, PUBLICATION, TEACHING, CLINICAL_AUDIT, SELF_STUDY
  provider              String?                 // who provided the CPD
  points                Decimal                 @db.Decimal(5, 1)
  dateCompleted         DateTime
  certificateUrl        String?
  verified              Boolean                 @default(false)

  createdAt             DateTime                @default(now())

  @@index([professionalId])
  @@index([dateCompleted])
}

// ─── CadreHealth: Work History ───

model CadreWorkHistory {
  id                    String                  @id @default(cuid())
  professionalId        String
  professional          CadreProfessional       @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  facilityId            String?
  facility              CadreFacility?          @relation(fields: [facilityId], references: [id])
  facilityName          String                  // stored even if facility not in system
  role                  String
  department            String?
  startDate             DateTime
  endDate               DateTime?
  isCurrent             Boolean                 @default(false)

  // Facility-side confirmation
  confirmedByFacility   Boolean                 @default(false)
  confirmedAt           DateTime?
  confirmedBy           String?

  createdAt             DateTime                @default(now())

  @@index([professionalId])
  @@index([facilityId])
}

// ─── CadreHealth: Facilities (Hospitals, Clinics, etc.) ───

model CadreFacility {
  id                    String                  @id @default(cuid())
  name                  String
  slug                  String                  @unique // for SEO: /hospitals/luth
  type                  CadreFacilityType
  description           String?                 @db.Text
  state                 String
  city                  String
  address               String?
  website               String?
  phone                 String?
  email                 String?
  bedCount              Int?
  yearEstablished       Int?
  isVerified            Boolean                 @default(false)

  // Aggregate ratings (computed, cached)
  overallRating         Decimal?                @db.Decimal(3, 2) // 1.00 - 5.00
  compensationRating    Decimal?                @db.Decimal(3, 2)
  payTimelinessRating   Decimal?                @db.Decimal(3, 2)
  workloadRating        Decimal?                @db.Decimal(3, 2)
  equipmentRating       Decimal?                @db.Decimal(3, 2)
  managementRating      Decimal?                @db.Decimal(3, 2)
  safetyRating          Decimal?                @db.Decimal(3, 2)
  trainingRating        Decimal?                @db.Decimal(3, 2)
  accommodationRating   Decimal?                @db.Decimal(3, 2)
  totalReviews          Int                     @default(0)
  wouldRecommendPct     Decimal?                @db.Decimal(5, 2) // 0-100

  // Extended aggregate ratings (v2)
  interCadreRating      Decimal?                @db.Decimal(3, 2)
  fairnessRating        Decimal?                @db.Decimal(3, 2)
  harassmentRating      Decimal?                @db.Decimal(3, 2)
  worklifeRating        Decimal?                @db.Decimal(3, 2)
  clinicalGovernanceRating Decimal?              @db.Decimal(3, 2)
  integrityRating       Decimal?                @db.Decimal(3, 2)

  // Key binary aggregates
  paidOnTimePct         Decimal?                @db.Decimal(5, 2) // % who say paid on time
  witnessedBullyingPct  Decimal?                @db.Decimal(5, 2)
  wouldBringFamilyPct   Decimal?                @db.Decimal(5, 2) // % who would bring family for treatment
  situationImprovingPct Decimal?                @db.Decimal(5, 2)

  // Relations
  reviews               CadreFacilityReview[]
  salaryReports         CadreSalaryReport[]
  workHistories         CadreWorkHistory[]
  currentStaff          CadreProfessional[]     @relation("CurrentStaff")
  mandates              CadreMandate[]
  employerAccount       CadreEmployerAccount?

  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  @@index([state, city])
  @@index([type])
  @@index([slug])
  @@index([overallRating])
}

// ─── CadreHealth: Employer Accounts ───

model CadreEmployerAccount {
  id                    String                  @id @default(cuid())
  facilityId            String?                 @unique
  facility              CadreFacility?          @relation(fields: [facilityId], references: [id])

  companyName           String
  contactName           String
  contactEmail          String                  @unique
  contactPhone          String?
  passwordHash          String

  isVerified            Boolean                 @default(false)

  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  @@index([contactEmail])
}

// ─── CadreHealth: Facility Reviews (Glassdoor model) ───

model CadreFacilityReview {
  id                    String                  @id @default(cuid())
  professionalId        String
  professional          CadreProfessional       @relation(fields: [professionalId], references: [id])
  facilityId            String
  facility              CadreFacility           @relation(fields: [facilityId], references: [id])

  // Ratings (1-5 scale)
  overallRating         Int                     // 1-5
  compensationRating    Int?                    // 1-5
  payTimelinessRating   Int?                    // 1-5 (do they pay on time?)
  workloadRating        Int?                    // 1-5 (call duty fairness)
  equipmentRating       Int?                    // 1-5 (does equipment work?)
  managementRating      Int?                    // 1-5
  safetyRating          Int?                    // 1-5 (staff safety)
  trainingRating        Int?                    // 1-5 (career development)
  accommodationRating   Int?                    // 1-5 (staff quarters)

  // Extended dimensions (v2) - each is 1-5 scale, null if not answered
  interCadreRating      Int?                    // Inter-cadre relationships
  fairnessRating        Int?                    // Fairness, inclusion & discrimination
  harassmentRating      Int?                    // Safety, harassment & dignity
  worklifeRating        Int?                    // Work-life balance
  clinicalGovernanceRating Int?                  // Clinical governance & patient care
  integrityRating       Int?                    // Institutional integrity

  // Detailed sub-questions (stored as JSON for flexibility)
  detailedResponses     Json?                   // Full detailed responses keyed by question ID

  // Key binary questions (indexed for aggregation)
  paidOnTime            Boolean?                // salary paid on time
  salaryDelayMonths     String?                 // "0" / "1-2" / "3-5" / "6+"
  witnessedInterCadreBullying Boolean?
  witnessedEthnicDiscrimination Boolean?
  witnessedReligiousDiscrimination Boolean?
  witnessedGenderDiscrimination Boolean?
  witnessedSexualHarassment Boolean?
  witnessedVerbalAbuse  Boolean?
  callDuration          String?                 // "<12hrs" / "12-24hrs" / "24-36hrs" / "36hrs+"
  getPostCallOff        String?                 // "ALWAYS" / "SOMETIMES" / "NEVER"
  wouldBringFamilyHere  String?                 // "YES" / "NO" / "DEPENDS"
  wouldRecommendToPatient String?               // "YES" / "NO" / "WITH_RESERVATIONS"
  situationTrend        String?                 // "IMPROVING" / "SAME" / "DECLINING"
  bestThing             String?                 @db.Text
  worstThing            String?                 @db.Text

  // Review completeness
  isDetailedReview      Boolean                 @default(false)

  // Content
  pros                  String?                 @db.Text
  cons                  String?                 @db.Text
  advice                String?                 @db.Text // advice to management
  wouldRecommend        Boolean?

  // Context
  roleAtFacility        String?
  cadreAtFacility       CadreProfessionalCadre?
  employmentType        String?                 // FULL_TIME, LOCUM, NYSC, HOUSE_OFFICER, RESIDENCY
  workedFromYear        Int?
  workedToYear          Int?
  isCurrentEmployee     Boolean                 @default(false)

  // Moderation
  isApproved            Boolean                 @default(true)
  isFlagged             Boolean                 @default(false)
  flagReason            String?
  helpfulCount          Int                     @default(0)

  createdAt             DateTime                @default(now())

  @@unique([professionalId, facilityId]) // one review per facility per person
  @@index([facilityId])
  @@index([overallRating])
  @@index([createdAt])
}

// ─── CadreHealth: Salary Reports (anonymous, aggregated) ───

model CadreSalaryReport {
  id                    String                  @id @default(cuid())
  professionalId        String
  professional          CadreProfessional       @relation(fields: [professionalId], references: [id])
  facilityId            String?
  facility              CadreFacility?          @relation(fields: [facilityId], references: [id])

  // Core salary data
  cadre                 CadreProfessionalCadre
  role                  String                  // e.g. "House Officer", "Registrar", "Consultant"
  facilityType          CadreFacilityType?
  state                 String
  city                  String?
  yearsOfExperience     Int?

  // Compensation breakdown
  baseSalary            Decimal                 @db.Decimal(12, 2)
  currency              String                  @default("NGN")
  allowances            Decimal?                @db.Decimal(12, 2) // housing, transport, hazard, etc.
  callDutyPay           Decimal?                @db.Decimal(12, 2)
  locumIncome           Decimal?                @db.Decimal(12, 2) // supplementary locum income
  totalMonthlyTakeHome  Decimal?                @db.Decimal(12, 2)

  // Pay reliability
  paidOnTime            Boolean?
  averagePayDelayDays   Int?

  reportedAt            DateTime                @default(now())

  @@index([cadre, state])
  @@index([facilityId])
  @@index([reportedAt])
}

// ─── CadreHealth: Career Readiness Assessment ───

model CadreReadinessAssessment {
  id                    String                  @id @default(cuid())
  professionalId        String?                 // null for anonymous/pre-registration assessments
  professional          CadreProfessional?      @relation(fields: [professionalId], references: [id])

  // Input data (the questionnaire answers)
  cadre                 CadreProfessionalCadre
  yearsOfExperience     Int
  hasFullRegistration   Boolean
  hasPracticingLicense  Boolean
  hasCOGS               Boolean
  postgraduateLevel     String?                 // NONE, MASTERS, FELLOWSHIP, DOCTORATE
  ieltsScore            Decimal?                @db.Decimal(3, 1)
  oetPassed             Boolean?
  plab1Passed           Boolean?
  plab2Passed           Boolean?
  usmlePassed           String?                 // NONE, STEP1, STEP2, STEP3
  cpdPointsCurrent      Int?
  cpdPointsRequired     Int?
  additionalCerts       String[]                // ACLS, BLS, ATLS, etc.

  // Computed scores
  domesticScore         Int                     // 0-100
  ukScore               Int                     // 0-100
  usScore               Int                     // 0-100
  canadaScore           Int                     // 0-100
  gulfScore             Int                     // 0-100
  gapAnalysis           Json?                   // structured gap breakdown

  // Lead capture (collected before showing results)
  captureFirstName      String?
  captureLastName       String?
  captureEmail          String?
  capturePhone          String?

  // Tracking
  ipAddress             String?
  wasShared             Boolean                 @default(false) // did they share the result?
  convertedToProfile    Boolean                 @default(false) // did they create a profile after?

  createdAt             DateTime                @default(now())

  @@index([professionalId])
  @@index([cadre])
  @@index([createdAt])
}

// ─── CadreHealth: Recruitment Mandates ───

model CadreMandate {
  id                    String                  @id @default(cuid())
  title                 String                  // "Medical Director - House of Refuge"
  description           String?                 @db.Text
  facilityId            String?
  facility              CadreFacility?          @relation(fields: [facilityId], references: [id])
  facilityName          String?                 // if facility not in system yet
  clientContact         String?

  // Requirements
  cadre                 CadreProfessionalCadre
  subSpecialty           String?
  minYearsExperience    Int?
  requiredQualifications String[]
  preferredQualifications String[]
  valuesRequirements    String?                 // e.g. "Christian faith" for House of Refuge
  locationState         String?
  locationCity          String?
  isRemoteOk            Boolean                 @default(false)
  isRelocationRequired  Boolean                 @default(false)

  // Terms
  type                  CadreMandateType
  salaryRangeMin        Decimal?                @db.Decimal(12, 2)
  salaryRangeMax        Decimal?                @db.Decimal(12, 2)
  salaryCurrency        String?                 @default("NGN")
  urgency               String?                 // LOW, MEDIUM, HIGH, URGENT

  // Pipeline
  status                CadreMandateStatus      @default(OPEN)
  publishedAt           DateTime?
  closedAt              DateTime?

  // Public job board
  isPublished           Boolean                 @default(false)
  slug                  String?                 @unique
  applicationCount      Int                     @default(0)

  // Relations
  matches               CadreMandateMatch[]

  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  @@index([status])
  @@index([cadre])
  @@index([type])
  @@index([isPublished, status])
  @@index([slug])
}

// ─── CadreHealth: Mandate-Professional Matching ───

model CadreMandateMatch {
  id                    String                  @id @default(cuid())
  mandateId             String
  mandate               CadreMandate            @relation(fields: [mandateId], references: [id], onDelete: Cascade)
  professionalId        String
  professional          CadreProfessional       @relation(fields: [professionalId], references: [id])

  // Matching
  matchScore            Int?                    // 0-100 AI-computed
  matchExplanation      String?                 @db.Text
  rank                  Int?

  // Pipeline
  status                String                  @default("MATCHED") // MATCHED, CONTACTED, INTERESTED, INTERVIEWING, OFFERED, PLACED, DECLINED, WITHDRAWN
  contactedAt           DateTime?
  respondedAt           DateTime?
  response              String?                 // INTERESTED, NOT_INTERESTED, NO_RESPONSE
  notes                 String?                 @db.Text

  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  @@unique([mandateId, professionalId])
  @@index([mandateId])
  @@index([professionalId])
  @@index([status])
}

// ─── CadreHealth: Outreach & Engagement ──────────────────────────────────────

enum CadreOutreachStatus {
  PENDING          // not yet contacted
  ENRICHING        // running email/phone verification
  READY            // enriched, ready for outreach
  WHATSAPP_SENT    // template message sent
  WHATSAPP_REPLIED // professional replied, Claude engaging
  SMS_SENT         // SMS fallback sent
  EMAIL_SENT       // email fallback sent
  CONVERTED        // claimed profile / set password
  NOT_INTERESTED   // opted out
  UNREACHABLE      // all channels failed
  EMIGRATED        // confirmed abroad (still valuable)
  RETIRED          // no longer practising
}

enum CadreOutreachChannel {
  WHATSAPP
  SMS
  EMAIL
}

model CadreOutreachRecord {
  id                    String                  @id @default(cuid())
  professionalId        String
  professional          CadreProfessional       @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  // Current state
  status                CadreOutreachStatus     @default(PENDING)
  tier                  String?                 // A, B, C

  // Data enrichment results
  emailValid            Boolean?
  emailActivityScore    Int?                    // 0-100 from ZeroBounce
  phoneActive           Boolean?
  phoneCarrier          String?
  phoneRoaming          Boolean?                // emigration signal
  hasWhatsApp           Boolean?

  // Outreach tracking
  whatsAppSentAt        DateTime?
  whatsAppDeliveredAt   DateTime?
  whatsAppReadAt        DateTime?
  whatsAppRepliedAt     DateTime?
  smsSentAt             DateTime?
  emailSentAt           DateTime?

  // Conversion
  convertedAt           DateTime?
  profileClaimedAt      DateTime?

  // Meta
  lastContactedAt       DateTime?
  contactAttempts       Int                     @default(0)
  nextContactAt         DateTime?               // scheduled next attempt
  notes                 String?

  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  @@unique([professionalId])
  @@index([status])
  @@index([tier])
  @@index([nextContactAt])
}

model CadreWhatsAppMessage {
  id                    String                  @id @default(cuid())
  professionalId        String
  professional          CadreProfessional       @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  // Message details
  direction             String                  // INBOUND, OUTBOUND
  channel               CadreOutreachChannel    @default(WHATSAPP)
  content               String                  @db.Text
  whatsAppMessageId     String?                 // Meta message ID
  templateName          String?                 // for outbound template messages

  // Claude processing
  intentDetected        String?                 // INTERESTED, NOT_INTERESTED, QUESTION, EMIGRATED, RETIRED, PROFILE_UPDATE, UNKNOWN
  profileUpdates        Json?                   // structured updates Claude extracted
  claudeModelUsed       String?

  // Status
  deliveryStatus        String?                 // sent, delivered, read, failed
  errorMessage          String?

  createdAt             DateTime                @default(now())

  @@index([professionalId, createdAt])
  @@index([direction])
  @@index([createdAt])
}

// ─── CadreHealth: Facility Referrals ───

model CadreFacilityReferral {
  id                    String                  @id @default(cuid())
  referredById          String
  referredBy            CadreProfessional       @relation("FacilityReferrals", fields: [referredById], references: [id])

  facilityName          String
  contactName           String?
  contactEmail          String?
  contactPhone          String?
  facilityType          CadreFacilityType?
  state                 String?
  city                  String?
  needType              String                  // RECRUITMENT, LOCUM_STAFFING, CONSULTING, OTHER
  notes                 String?                 @db.Text

  status                String                  @default("PENDING") // PENDING, CONTACTED, CONVERTED, REJECTED
  adminNotes            String?                 @db.Text

  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  @@index([referredById])
  @@index([status])
}

// ─── CadreHealth: Career Intelligence Reports ───

model CadreCareerReport {
  id                    String                  @id @default(cuid())
  professionalId        String
  professional          CadreProfessional       @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  marketPosition        Json?    // percentile, peer comparison
  compensationBenchmark Json?    // salary range, where they fall
  skillsGap             Json?    // missing certs/quals with impact scores
  careerPaths           Json?    // 3 suggested trajectories
  internationalReadiness Json?   // country-by-country assessment
  nextSteps             Json?    // prioritized action items
  fullReport            Json?    // raw response

  createdAt             DateTime @default(now())

  @@index([professionalId, createdAt])
}

// ─── CadreHealth: Career Advisor Messages ───

model CadreAdvisorMessage {
  id                    String                  @id @default(cuid())
  professionalId        String
  professional          CadreProfessional       @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  role                  String   // "user" or "advisor"
  content               String   @db.Text

  createdAt             DateTime @default(now())

  @@index([professionalId, createdAt])
}

// ─── CadreHealth: Newsletter Subscribers ───

model CadreNewsletterSubscriber {
  id            String   @id @default(cuid())
  email         String   @unique
  source        String   @default("landing") // landing, readiness, etc.
  cadreFilter   String?
  stateFilter   String?
  subscribedAt  DateTime @default(now())
}

// ─── CadreHealth: Mentorship ───

enum CadreMentorStatus {
  PENDING      // applied to be mentor, awaiting approval
  ACTIVE       // approved and available
  PAUSED       // temporarily unavailable
  INACTIVE     // deactivated
}

enum CadreMentorshipStatus {
  REQUESTED    // mentee requested
  ACTIVE       // mentor accepted
  COMPLETED    // mentorship ended naturally
  DECLINED     // mentor declined
  CANCELLED    // either party cancelled
}

model CadreMentorProfile {
  id                    String                  @id @default(cuid())
  professionalId        String                  @unique
  professional          CadreProfessional       @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  status                CadreMentorStatus       @default(PENDING)

  // What they mentor on
  mentorAreas           String[]                // e.g. "UK Migration", "Fellowship Preparation", "Career Transition"
  mentorCadres          String[]                // which cadres they can mentor (CadreProfessionalCadre values)
  bio                   String?                 @db.Text
  maxMentees            Int                     @default(3)
  currentMenteeCount    Int                     @default(0)

  // Availability
  availabilityType      String                  @default("ASYNC") // ASYNC, SCHEDULED, BOTH
  availabilityNote      String?                 // e.g. "Weekday evenings WAT"

  // Partner organization
  partnerOrg            String?                 // MANSAG, ANPA, DFC, NDF_SA, OTHER
  partnerOrgVerified    Boolean                 @default(false)

  // Diaspora info
  countryOfPractice     String?                 // where they currently practise
  yearsAbroad           Int?

  // Stats
  totalMentorships      Int                     @default(0)
  averageRating         Decimal?                @db.Decimal(3, 2)
  totalRatings          Int                     @default(0)

  mentorships           CadreMentorship[]       @relation("MentorMentorships")
  coachingSessions      CadreCoachingSession[]

  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  @@index([status])
  @@index([partnerOrg])
}

model CadreMentorship {
  id                    String                  @id @default(cuid())
  mentorProfileId       String
  mentorProfile         CadreMentorProfile      @relation("MentorMentorships", fields: [mentorProfileId], references: [id])
  menteeId              String
  mentee                CadreProfessional       @relation("MenteeMentorships", fields: [menteeId], references: [id])

  status                CadreMentorshipStatus   @default(REQUESTED)
  topic                 String                  // what they want help with
  message               String?                 @db.Text // initial message from mentee

  // Tracking
  acceptedAt            DateTime?
  completedAt           DateTime?
  lastActivityAt        DateTime?

  // Rating (by mentee after completion)
  rating                Int?                    // 1-5
  feedback              String?                 @db.Text

  messages              CadreMentorshipMessage[]

  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  @@index([mentorProfileId])
  @@index([menteeId])
  @@index([status])
}

model CadreMentorshipMessage {
  id                    String                  @id @default(cuid())
  mentorshipId          String
  mentorship            CadreMentorship         @relation(fields: [mentorshipId], references: [id], onDelete: Cascade)
  senderId              String                  // professional ID of sender
  content               String                  @db.Text

  createdAt             DateTime                @default(now())

  @@index([mentorshipId, createdAt])
}

// ─── CadreHealth: Notifications ───

model CadreNotification {
  id                    String                  @id @default(cuid())
  professionalId        String
  professional          CadreProfessional       @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  type                  String                  // LICENSE_EXPIRY, JOB_MATCH, MENTORSHIP_REQUEST, MENTORSHIP_ACCEPTED, NEW_REVIEW, SALARY_DATA, PROFILE_VIEW, SYSTEM
  title                 String
  message               String
  link                  String?                 // URL to navigate to when clicked
  isRead                Boolean                 @default(false)

  createdAt             DateTime                @default(now())

  @@index([professionalId, isRead, createdAt])
}

// ─── CadreHealth: Subscriptions & Coaching ───────────────────────────────────

enum CadreSubscriptionPlan {
  FREE
  PRO
}

enum CadreSubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  EXPIRED
}

model CadreSubscription {
  id                    String                      @id @default(cuid())
  professionalId        String                      @unique
  professional          CadreProfessional           @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  plan                  CadreSubscriptionPlan       @default(FREE)
  status                CadreSubscriptionStatus     @default(ACTIVE)

  // Paystack subscription
  paystackCustomerCode  String?
  paystackSubCode       String?                     // subscription code from Paystack
  paystackEmailToken    String?                     // email token for managing sub
  paystackPlanCode      String?                     // plan code on Paystack

  // Billing
  amountNGN             Int                         @default(0)    // price in Naira
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  cancelledAt           DateTime?

  // Usage tracking (for free tier gating)
  aiMessagesThisMonth   Int                         @default(0)
  aiMessagesResetAt     DateTime                    @default(now())

  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt

  @@index([status])
}

enum CadreCoachingSessionStatus {
  PENDING_PAYMENT
  PAID
  SCHEDULED
  COMPLETED
  CANCELLED
  REFUNDED
}

model CadreCoachingSession {
  id                    String                          @id @default(cuid())
  menteeId              String
  mentee                CadreProfessional               @relation(fields: [menteeId], references: [id], onDelete: Cascade)

  mentorProfileId       String
  mentorProfile         CadreMentorProfile              @relation(fields: [mentorProfileId], references: [id])

  // Session details
  topic                 String
  status                CadreCoachingSessionStatus      @default(PENDING_PAYMENT)
  scheduledAt           DateTime?
  completedAt           DateTime?
  durationMinutes       Int                             @default(45)
  notes                 String?                         @db.Text

  // Payment
  amountNGN             Int                             @default(5000)
  paystackRef           String?                         @unique
  paidAt                DateTime?

  // Rating (after completion)
  rating                Int?                            // 1-5
  feedback              String?

  createdAt             DateTime                        @default(now())
  updatedAt             DateTime                        @updatedAt

  @@index([menteeId, status])
  @@index([mentorProfileId, status])
}

// ─── AGENT PLATFORM ──────────────────────────────────────────────────────────

enum AgentStatus {
  APPLIED
  VETTING
  APPROVED
  SUSPENDED
  DEACTIVATED
}

enum AgentOpportunityStatus {
  DRAFT
  OPEN
  ASSIGNED
  PAUSED
  CLOSED
  COMPLETED
}

enum AgentDealStage {
  PROSPECT
  CONTACTED
  PITCHED
  NEGOTIATING
  VERBAL_COMMIT
  CLOSED_WON
  CLOSED_LOST
  DISQUALIFIED
}

enum CommissionType {
  FIXED_PER_DEAL
  PERCENTAGE
  TIERED
  RECURRING
}

enum CommissionStatus {
  PENDING
  VERIFIED
  APPROVED
  PROCESSING
  PAID
  DISPUTED
  CANCELLED
}

model SalesAgent {
  id                String       @id @default(cuid())
  email             String       @unique
  phone             String
  passwordHash      String?
  firstName         String
  lastName          String
  photo             String?

  company           String?
  title             String?
  bio               String?      @db.Text
  location          String?
  state             String?
  country           String       @default("Nigeria")

  industries        String[]
  salesExperience   Int?
  referralSource    String?
  linkedinUrl       String?

  userId            String?      @unique
  user              User?        @relation(fields: [userId], references: [id])

  status            AgentStatus  @default(APPLIED)
  vettedById        String?
  vettedAt          DateTime?
  vetNotes          String?      @db.Text

  bankName          String?
  accountNumber     String?
  accountName       String?

  isPortalEnabled   Boolean      @default(false)
  lastLoginAt       DateTime?
  resetToken        String?
  resetTokenExpiry  DateTime?
  emailVerified     Boolean      @default(false)
  emailVerifyToken  String?

  totalDeals        Int          @default(0)
  totalRevenue      Decimal      @default(0) @db.Decimal(14, 2)
  totalCommission   Decimal      @default(0) @db.Decimal(14, 2)

  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  opportunityAssignments AgentOpportunityAssignment[]
  deals                  AgentDeal[]
  commissions            AgentCommission[]
  payouts                AgentPayout[]
  documents              AgentDocument[]

  // Communications CRM back-relations
  communications         Communication[]

  @@index([status])
  @@index([email])
}

model AgentDocument {
  id          String     @id @default(cuid())
  agentId     String
  agent       SalesAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  type        String
  name        String
  fileUrl     String
  uploadedAt  DateTime   @default(now())
  verifiedAt  DateTime?

  @@index([agentId])
}

model AgentOpportunity {
  id                String                  @id @default(cuid())
  opportunityCode   String                  @unique

  title             String
  description       String                  @db.Text
  productType       String
  serviceCategory   String?

  clientId          String?
  client            Client?                 @relation(fields: [clientId], references: [id])
  clientName        String

  engagementId      String?
  engagement        Engagement?             @relation(fields: [engagementId], references: [id])
  trackId           String?

  territories       String[]
  targetIndustries  String[]
  targetDescription String?                 @db.Text

  commissionType    CommissionType
  commissionValue   Decimal                 @db.Decimal(10, 2)
  commissionCurrency Currency               @default(NGN)
  commissionTiers   Json?
  recurringMonths   Int?

  expectedDealValueMin Decimal?             @db.Decimal(14, 2)
  expectedDealValueMax Decimal?             @db.Decimal(14, 2)

  startDate         DateTime
  endDate           DateTime?
  status            AgentOpportunityStatus  @default(DRAFT)
  maxAgents         Int?

  pitchDeckUrl      String?
  briefingDocUrl    String?

  createdById       String?
  notes             String?                 @db.Text

  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  assignments       AgentOpportunityAssignment[]
  deals             AgentDeal[]

  @@index([status])
  @@index([clientId])
  @@index([engagementId])
}

model AgentOpportunityAssignment {
  id              String             @id @default(cuid())
  opportunityId   String
  opportunity     AgentOpportunity   @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  agentId         String
  agent           SalesAgent         @relation(fields: [agentId], references: [id], onDelete: Cascade)

  status          String             @default("APPLIED")
  appliedAt       DateTime           @default(now())
  approvedAt      DateTime?
  approvedById    String?

  assignedTerritory String?

  dealsWon        Int                @default(0)
  totalRevenue    Decimal            @default(0) @db.Decimal(14, 2)
  totalCommission Decimal            @default(0) @db.Decimal(14, 2)

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([opportunityId, agentId])
  @@index([agentId])
  @@index([opportunityId])
}

model AgentDeal {
  id              String           @id @default(cuid())
  dealCode        String           @unique
  opportunityId   String
  opportunity     AgentOpportunity @relation(fields: [opportunityId], references: [id])
  agentId         String
  agent           SalesAgent       @relation(fields: [agentId], references: [id])

  prospectName    String
  prospectOrg     String?
  prospectEmail   String?
  prospectPhone   String?
  prospectTitle   String?

  stage           AgentDealStage   @default(PROSPECT)
  stageHistory    Json?

  dealValue       Decimal?         @db.Decimal(14, 2)
  dealCurrency    Currency         @default(NGN)
  dealDescription String?          @db.Text

  closedAt        DateTime?
  closedValue     Decimal?         @db.Decimal(14, 2)
  proofDocUrl     String?

  verifiedById    String?
  verifiedAt      DateTime?
  verificationNotes String?        @db.Text

  nextFollowUpAt  DateTime?
  notes           String?          @db.Text

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  commissions     AgentCommission[]

  @@index([agentId])
  @@index([opportunityId])
  @@index([stage])
}

model AgentCommission {
  id              String           @id @default(cuid())
  dealId          String
  deal            AgentDeal        @relation(fields: [dealId], references: [id])
  agentId         String
  agent           SalesAgent       @relation(fields: [agentId], references: [id])

  commissionType  CommissionType
  baseValue       Decimal          @db.Decimal(14, 2)
  rate            Decimal          @db.Decimal(10, 2)
  amount          Decimal          @db.Decimal(14, 2)
  currency        Currency         @default(NGN)

  period          String?
  periodNumber    Int?

  status          CommissionStatus @default(PENDING)
  verifiedAt      DateTime?
  approvedAt      DateTime?
  approvedById    String?
  paidAt          DateTime?

  payoutId        String?
  payout          AgentPayout?     @relation(fields: [payoutId], references: [id])

  disputeReason   String?          @db.Text
  notes           String?          @db.Text

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([agentId])
  @@index([dealId])
  @@index([status])
  @@index([payoutId])
}

model AgentPayout {
  id              String           @id @default(cuid())
  payoutCode      String           @unique
  agentId         String
  agent           SalesAgent       @relation(fields: [agentId], references: [id])

  totalAmount     Decimal          @db.Decimal(14, 2)
  currency        Currency         @default(NGN)
  status          String           @default("PENDING")

  paymentMethod   String?
  paymentRef      String?
  bankName        String?
  accountNumber   String?
  accountName     String?

  processedById   String?
  processedAt     DateTime?
  confirmedAt     DateTime?
  failureReason   String?

  notes           String?          @db.Text

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  commissions     AgentCommission[]

  @@index([agentId])
  @@index([status])
}

// ─── FOUNDER IDEATION ────────────────────────────────────────────────────────

model FounderIdea {
  id          String   @id @default(cuid())
  founderId   String
  founder     FounderProfile @relation(fields: [founderId], references: [id], onDelete: Cascade)

  title       String
  content     String   @db.Text
  category    String?  // PRODUCT, REVENUE, PARTNERSHIP, GROWTH, OPERATIONS, OTHER
  priority    String   @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  status      String   @default("CAPTURED") // CAPTURED, EXPLORING, IN_PROGRESS, PARKED, DONE

  nuruNotes   String?  @db.Text // AI analysis/suggestions
  tags        String[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([founderId])
  @@index([status])
}

model FounderDailyPulse {
  id          String   @id @default(cuid())
  founderId   String
  founder     FounderProfile @relation(fields: [founderId], references: [id], onDelete: Cascade)

  date        DateTime @db.Date
  summary     String   @db.Text // AI-generated daily briefing
  insights    Json?    // structured insights [{type, title, detail, priority}]
  metrics     Json?    // snapshot of key metrics at time of generation

  createdAt   DateTime @default(now())

  @@unique([founderId, date])
  @@index([founderId])
}

model FounderDocument {
  id          String   @id @default(cuid())
  founderId   String
  founder     FounderProfile @relation(fields: [founderId], references: [id], onDelete: Cascade)

  title       String
  description String?  @db.Text
  content     String?  @db.Text  // for text/paste content
  fileUrl     String?             // for uploaded files (R2)
  fileType    String?             // PDF, DOCX, XLSX, PPTX, etc.
  fileSize    Int?                // bytes

  category    String   // STRATEGY, FINANCE, LEGAL, CLIENT, OPERATIONS, MARKET_INTEL, PARTNERSHIP, PERSONAL
  tags        String[]
  isPinned    Boolean  @default(false)
  isPrivate   Boolean  @default(true) // founder-eyes-only by default

  reviewDate  DateTime? // reminder to review
  reviewNote  String?

  nuruSummary String?  @db.Text  // AI-generated summary
  nuruNotes   String?  @db.Text  // AI analysis

  viewCount   Int      @default(0)
  lastViewedAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([founderId])
  @@index([category])
  @@index([isPinned])
}

// ─── CAMPAIGN MANAGEMENT ─────────────────────────────────────────────────────

enum CampaignBrand {
  C4A
  CADREHEALTH
  MAAROVA
}

enum CampaignPostStatus {
  IDEA
  DRAFTING
  READY_FOR_REVIEW
  APPROVED
  SCHEDULED
  PUBLISHED
  REJECTED
}

enum SocialPlatform {
  LINKEDIN
  TWITTER
  INSTAGRAM
  TIKTOK
  FACEBOOK
  WHATSAPP
  EMAIL
}

model Campaign {
  id          String        @id @default(cuid())
  name        String
  description String?       @db.Text
  brand       CampaignBrand
  objective   String?       // AWARENESS, ENGAGEMENT, LEADS, CONVERSIONS, RECRUITMENT
  startDate   DateTime?
  endDate     DateTime?
  status      String        @default("PLANNING") // PLANNING, ACTIVE, PAUSED, COMPLETED
  tags        String[]

  createdById String?
  notes       String?       @db.Text

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  posts       CampaignPost[]

  @@index([brand])
  @@index([status])
}

model CampaignPost {
  id           String             @id @default(cuid())
  campaignId   String?
  campaign     Campaign?          @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  brand        CampaignBrand
  platforms    SocialPlatform[]
  contentPillar String?           // THOUGHT_LEADERSHIP, CASE_STUDY, SALARY_DATA, CAREER_GUIDANCE, PRODUCT, TEAM_CULTURE, NEWS

  title        String             // internal reference title
  body         String             @db.Text // post copy
  hashtags     String[]
  mediaUrls    String[]           // uploaded images/videos
  mediaType    String?            // IMAGE, VIDEO, CAROUSEL, REEL, STORY

  scheduledAt  DateTime?
  publishedAt  DateTime?
  status       CampaignPostStatus @default(IDEA)

  // Approval
  createdById  String?
  reviewedById String?
  reviewNote   String?            @db.Text
  approvedAt   DateTime?

  // Performance (manually entered or API-fed)
  impressions  Int?
  reach        Int?
  engagements  Int?
  clicks       Int?
  shares       Int?
  comments     Int?
  saves        Int?

  // Nuru
  nuruSuggestion String?          @db.Text // AI-generated improvement suggestions

  externalUrl  String?            // link to published post

  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([brand])
  @@index([status])
  @@index([scheduledAt])
  @@index([campaignId])
}

// ═══════════════════════════════════════════════════════════════════════════
// COMMUNICATIONS CRM
// Per-contact timeline of all touchpoints across email, calls, meetings,
// WhatsApp, SMS, LinkedIn, and internal notes. Polymorphic subject so a
// single record can attach to consultants, clients, applicants, etc.
// ═══════════════════════════════════════════════════════════════════════════

enum CommunicationSubjectType {
  CONSULTANT          // links to User where role=CONSULTANT
  CLIENT              // links to Client (organisation)
  CLIENT_CONTACT      // links to ClientContact (specific person)
  TALENT_APPLICATION  // links to TalentApplication
  CADRE_PROFESSIONAL  // links to CadreProfessional
  PARTNER_FIRM        // links to PartnerFirm
  SALES_AGENT         // links to SalesAgent
  DISCOVERY_CALL      // links to DiscoveryCall
  MAAROVA_USER        // links to MaarovaUser
  PROSPECT            // not yet a record (free-text name + contact)
}

enum CommunicationType {
  EMAIL
  PHONE_CALL
  VIDEO_CALL
  IN_PERSON_MEETING
  WHATSAPP
  SMS
  LINKEDIN_MESSAGE
  NOTE                // internal-only, no actual contact made
  OTHER
}

enum CommunicationDirection {
  OUTBOUND
  INBOUND
  INTERNAL            // a note about the contact, no contact made
}

enum CommunicationStatus {
  DRAFT
  SCHEDULED
  LOGGED              // manually entered after the fact
  SENT                // sent through the platform
  DELIVERED
  OPENED
  CLICKED
  REPLIED
  BOUNCED
  FAILED
  CANCELLED
}

enum CommunicationSentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum CommunicationVisibility {
  PRIVATE             // only loggedBy can see
  TEAM                // anyone with elevated role on the platform
  PUBLIC              // includes the contact via portal (future)
}

model Communication {
  id              String                  @id @default(cuid())

  // ── Subject (who this is about) ──────────────────────────────────────
  subjectType     CommunicationSubjectType
  // We keep explicit nullable FKs for indexing/joining. Exactly one matches subjectType.
  consultantId    String?
  consultant      User?                   @relation("CommSubjectConsultant", fields: [consultantId], references: [id], onDelete: Cascade)
  clientId        String?
  client          Client?                 @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientContactId String?
  clientContact   ClientContact?          @relation(fields: [clientContactId], references: [id], onDelete: Cascade)
  applicationId   String?
  application     TalentApplication?      @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  cadreProfessionalId String?
  cadreProfessional CadreProfessional?    @relation(fields: [cadreProfessionalId], references: [id], onDelete: Cascade)
  partnerFirmId   String?
  partnerFirm     PartnerFirm?            @relation(fields: [partnerFirmId], references: [id], onDelete: Cascade)
  salesAgentId    String?
  salesAgent      SalesAgent?             @relation(fields: [salesAgentId], references: [id], onDelete: Cascade)
  discoveryCallId String?
  discoveryCall   DiscoveryCall?          @relation(fields: [discoveryCallId], references: [id], onDelete: Cascade)
  maarovaUserId   String?
  maarovaUser     MaarovaUser?            @relation(fields: [maarovaUserId], references: [id], onDelete: Cascade)
  // For PROSPECT type or general fallback
  prospectName    String?
  prospectEmail   String?
  prospectPhone   String?

  // ── What happened ────────────────────────────────────────────────────
  type            CommunicationType
  direction       CommunicationDirection
  status          CommunicationStatus     @default(LOGGED)

  // ── Content ──────────────────────────────────────────────────────────
  subject         String?
  body            String?                 @db.Text
  bodyHtml        String?                 @db.Text
  attachmentUrls  String[]                @default([])

  // ── Timing ───────────────────────────────────────────────────────────
  occurredAt      DateTime                @default(now())
  scheduledFor    DateTime?
  sentAt          DateTime?
  deliveredAt     DateTime?
  openedAt        DateTime?
  clickedAt       DateTime?
  repliedAt       DateTime?
  durationMinutes Int?

  // ── Email-specific ───────────────────────────────────────────────────
  fromEmail       String?
  toEmails        String[]                @default([])
  ccEmails        String[]                @default([])
  bccEmails       String[]                @default([])
  externalId      String?                 // SMTP Message-ID for reply tracking
  inReplyTo       String?                 // SMTP In-Reply-To header

  // ── Meeting-specific ─────────────────────────────────────────────────
  meetingLink     String?
  meetingLocation String?

  // ── Phone-specific ───────────────────────────────────────────────────
  phoneNumber     String?

  // ── Outcome & follow-up ──────────────────────────────────────────────
  outcome         String?                 @db.Text
  sentiment       CommunicationSentiment?
  nextAction      String?
  nextActionDate  DateTime?
  nextActionAssignedToId String?
  nextActionAssignedTo   User?            @relation("CommNextAction", fields: [nextActionAssignedToId], references: [id])

  // ── Threading ────────────────────────────────────────────────────────
  threadId        String?
  replyToId       String?
  replyTo         Communication?          @relation("CommReplies", fields: [replyToId], references: [id])
  replies         Communication[]         @relation("CommReplies")

  // ── Bulk send linkage ────────────────────────────────────────────────
  bulkId          String?
  bulk            BulkCommunication?      @relation(fields: [bulkId], references: [id], onDelete: SetNull)

  // ── Metadata ─────────────────────────────────────────────────────────
  tags            String[]                @default([])
  metadata        Json?                   // misc structured data (campaign attribution, UTM, etc)
  isPinned        Boolean                 @default(false)
  isArchived      Boolean                 @default(false)

  // ── Audit ────────────────────────────────────────────────────────────
  loggedById      String
  loggedBy        User                    @relation("LoggedComms", fields: [loggedById], references: [id])
  visibility      CommunicationVisibility @default(TEAM)

  // ── NDPR / data protection ───────────────────────────────────────────
  lawfulBasis     CommunicationLawfulBasis @default(LEGITIMATE_INTEREST)
  retentionExpiresAt DateTime?            // null = no expiry policy applied yet
  redactedAt      DateTime?               // if set, body/subject/attachments were nulled
  redactedReason  String?

  // ── Many-to-many participant tracking (Pattern C) ────────────────────
  // Each row in CommunicationParticipant links this comm to other subjects
  // (e.g. an email FROM a consultant TO a client contact about a project).
  participants    CommunicationParticipant[]

  // ── Event log ────────────────────────────────────────────────────────
  events          CommunicationEvent[]

  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([subjectType])
  @@index([consultantId])
  @@index([clientId])
  @@index([clientContactId])
  @@index([applicationId])
  @@index([cadreProfessionalId])
  @@index([partnerFirmId])
  @@index([salesAgentId])
  @@index([loggedById])
  @@index([occurredAt])
  @@index([threadId])
  @@index([status])
  @@index([nextActionDate])
}

enum BulkCommunicationStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  CANCELLED
  FAILED
}

model BulkCommunication {
  id                 String                  @id @default(cuid())
  name               String
  templateId         String?
  template           CommunicationTemplate?  @relation(fields: [templateId], references: [id])
  type               CommunicationType       @default(EMAIL)
  subject            String?
  body               String                  @db.Text
  bodyHtml           String?                 @db.Text
  filterDescription  String?                 // human-readable filter that produced the recipient list
  recipientCount     Int                     @default(0)
  status             BulkCommunicationStatus @default(DRAFT)
  scheduledFor       DateTime?
  sentAt             DateTime?
  completedAt        DateTime?
  successCount       Int                     @default(0)
  failureCount       Int                     @default(0)
  createdById        String
  createdBy          User                    @relation("CreatedBulkComms", fields: [createdById], references: [id])
  communications     Communication[]
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  @@index([status])
  @@index([scheduledFor])
  @@index([createdById])
}

model CommunicationTemplate {
  id              String              @id @default(cuid())
  name            String              @unique
  description     String?
  category        String?             // CONSULTANT_OUTREACH, CLIENT_FOLLOWUP, APPLICATION_RESPONSE, etc.
  type            CommunicationType   @default(EMAIL)
  subject         String?
  body            String              @db.Text
  bodyHtml        String?             @db.Text
  variables       String[]            @default([])  // e.g. ["firstName", "company"]
  createdById     String
  createdBy       User                @relation("CreatedTemplates", fields: [createdById], references: [id])
  isActive        Boolean             @default(true)
  usageCount      Int                 @default(0)
  bulkSends       BulkCommunication[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([category])
  @@index([isActive])
}

// Suppression list: contacts who have opted out or bounced
model CommunicationSuppression {
  id          String   @id @default(cuid())
  email       String?
  phoneNumber String?
  reason      String   // OPTED_OUT, BOUNCED, COMPLAINT, MANUAL
  channel     CommunicationType?  // null = all channels
  notes       String?
  addedById   String?
  createdAt   DateTime @default(now())

  @@unique([email, channel])
  @@index([email])
  @@index([phoneNumber])
}

// Lawful basis under NDPR/GDPR for processing this communication.
enum CommunicationLawfulBasis {
  CONSENT
  CONTRACT
  LEGAL_OBLIGATION
  VITAL_INTEREST
  PUBLIC_TASK
  LEGITIMATE_INTEREST
}

enum CommunicationParticipantRole {
  FROM        // sender
  TO          // primary recipient
  CC
  BCC
  ABOUT       // mentioned/subject of the comm but not addressed
  PARTICIPANT // attendee on a call/meeting
}

// Many-to-many bridge: a single comm can involve multiple subjects in
// different roles. Example: email FROM consultant TO client contact ABOUT
// project. Each combination is one row here.
model CommunicationParticipant {
  id              String                       @id @default(cuid())
  communicationId String
  communication   Communication                @relation(fields: [communicationId], references: [id], onDelete: Cascade)
  role            CommunicationParticipantRole

  // Polymorphic subject. Exactly one of these IDs is set.
  subjectType     CommunicationSubjectType
  consultantId    String?
  consultant      User?                        @relation("CommParticipantConsultant", fields: [consultantId], references: [id], onDelete: Cascade)
  clientId        String?
  client          Client?                      @relation("CommParticipantClient", fields: [clientId], references: [id], onDelete: Cascade)
  clientContactId String?
  clientContact   ClientContact?               @relation("CommParticipantClientContact", fields: [clientContactId], references: [id], onDelete: Cascade)
  applicationId   String?
  application     TalentApplication?           @relation("CommParticipantApplication", fields: [applicationId], references: [id], onDelete: Cascade)
  cadreProfessionalId String?
  cadreProfessional CadreProfessional?         @relation("CommParticipantCadrePro", fields: [cadreProfessionalId], references: [id], onDelete: Cascade)
  partnerFirmId   String?
  partnerFirm     PartnerFirm?                 @relation("CommParticipantPartnerFirm", fields: [partnerFirmId], references: [id], onDelete: Cascade)

  // Free-text fallback for prospects or anyone not yet a record
  externalName    String?
  externalEmail   String?
  externalPhone   String?

  createdAt       DateTime                     @default(now())

  @@index([communicationId])
  @@index([role])
  @@index([consultantId])
  @@index([clientContactId])
  @@index([cadreProfessionalId])
  @@index([applicationId])
}

enum CommunicationEventType {
  CREATED
  STATUS_CHANGED
  SCHEDULED
  SENT
  DELIVERED
  OPENED
  CLICKED
  REPLIED
  BOUNCED
  COMPLAINED
  FAILED
  CANCELLED
  REDACTED
  EDITED
  PROVIDER_WEBHOOK   // raw inbound provider event captured for audit
}

// Append-only audit log of all events touching a communication.
// Used for debugging delivery, NDPR audit, and timeline regeneration.
model CommunicationEvent {
  id              String                  @id @default(cuid())
  communicationId String
  communication   Communication           @relation(fields: [communicationId], references: [id], onDelete: Cascade)
  type            CommunicationEventType
  fromStatus      CommunicationStatus?
  toStatus        CommunicationStatus?
  // Provider raw payload for SES/SendGrid/Postmark/Twilio webhooks
  provider        String?                 // "POSTMARK", "TWILIO", "ZOHO", "MANUAL"
  providerEventId String?
  providerPayload Json?
  // Who triggered (null for system/webhook events)
  actorUserId     String?
  actorUser       User?                   @relation("CommEventActor", fields: [actorUserId], references: [id])
  notes           String?
  createdAt       DateTime                @default(now())

  @@index([communicationId])
  @@index([type])
  @@index([createdAt])
  @@index([providerEventId])
}
