// ─── Founder Dashboard ────────────────────────────────────────────────────────

model FounderProfile {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  startDate    DateTime @default(now())
  currentPhase String   @default("Phase1_MVP")

  tasks            FounderTask[]
  milestones       FounderMilestone[]
  documentViews    FounderDocumentView[]
  aiConversations  FounderAIConversation[]
  metrics          FounderMetric[]
  ideas            FounderIdea[]
  dailyPulses      FounderDailyPulse[]
  documents        FounderDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FounderTask {
  id          String   @id @default(cuid())
  founderId   String
  founder     FounderProfile @relation(fields: [founderId], references: [id], onDelete: Cascade)

  title            String
  description      String?  @db.Text
  phase            String
  week             Int?
  priority         String   @default("medium")
  category         String   @default("general")

  dueDate          DateTime?
  completedAt      DateTime?
  status           String   @default("pending")

  estimatedMinutes Int?
  impact           String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([founderId, status])
  @@index([dueDate])
}

model FounderMilestone {
  id          String   @id @default(cuid())
  founderId   String
  founder     FounderProfile @relation(fields: [founderId], references: [id], onDelete: Cascade)

  name        String
  description String   @db.Text
  phase       String
  category    String

  targetDate  DateTime
  achievedAt  DateTime?
  status      String   @default("pending")

  celebration String?  @db.Text
  badge       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([founderId, status])
  @@index([targetDate])
}

model FounderDocumentView {
  id          String   @id @default(cuid())
  founderId   String
  founder     FounderProfile @relation(fields: [founderId], references: [id], onDelete: Cascade)

  documentName String
  category     String

  viewedAt         DateTime @default(now())
  timeSpentSeconds Int?

  @@index([founderId, viewedAt])
}

model FounderAIConversation {
  id          String   @id @default(cuid())
  founderId   String
  founder     FounderProfile @relation(fields: [founderId], references: [id], onDelete: Cascade)

  question    String   @db.Text
  answer      String   @db.Text
  helpful     Boolean?

  createdAt DateTime @default(now())

  @@index([founderId, createdAt])
}

model FounderMetric {
  id          String   @id @default(cuid())
  founderId   String
  founder     FounderProfile @relation(fields: [founderId], references: [id], onDelete: Cascade)

  metricType  String
  value       Decimal  @db.Decimal(15, 2)
  target      Decimal? @db.Decimal(15, 2)
  unit        String

  period      String
  periodDate  DateTime

  notes       String?  @db.Text

  createdAt DateTime @default(now())

  @@index([founderId, metricType, periodDate])
}

// ─── Talent Platform ──────────────────────────────────────────────────────────

enum ReferralType {
  CLIENT
  CONSULTANT
  STAFF
}

enum ReferralStatus {
  PENDING
  CONTACTED
  CONVERTED
  REJECTED
}

model Referral {
  id           String         @id @default(cuid())
  referrerId   String?
  referrer     User?          @relation(fields: [referrerId], references: [id], onDelete: SetNull)
  type         ReferralType
  name         String
  email        String
  phone        String?
  organisation String?
  suggestedRole String?
  notes        String?        @db.Text
  status       ReferralStatus @default(PENDING)
  leadId       String?
  lead         Lead?          @relation(fields: [leadId], references: [id])
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([referrerId])
  @@index([status, createdAt])
}

model Lead {
  id                 String   @id @default(cuid())
  source             String   // WEBSITE_CONTACT, MAAROVA_DEMO, REFERRAL, EVENT, COLD_OUTREACH, EXISTING_CLIENT
  status             String   @default("NEW") // NEW, RESEARCHING, OUTREACH, RESPONDED, DISCOVERY_SCHEDULED, PROPOSAL_SENT, CONVERTED, LOST

  // Contact info
  organizationName   String
  contactName        String
  contactEmail       String?
  contactPhone       String?
  contactRole        String?
  organizationType   String?
  country            String?
  city               String?

  // Inbound context (from forms)
  inboundMessage     String?  @db.Text  // message from contact/demo form
  inboundProjectType String?            // projectType from contact form
  maarovaStream      String?            // streamInterest from demo form
  maarovaLeaderCount Int?               // numberOfLeaders from demo form
  maarovaTimeline    String?            // timeline from demo form

  // Target research (for cold outreach and pre-call prep)
  decisionMakers     Json?              // [{name, role, linkedin}]
  knownPainPoints    String[]
  recentNews         String?  @db.Text
  competitorPresence String?  @db.Text  // who else is consulting for them
  estimatedSize      String?            // SMALL, MEDIUM, LARGE, ENTERPRISE
  serviceLineHook    String?            // which C4A service line is the angle

  // Outreach tracking
  outreachAttempts   Json?              // [{date, channel, notes, response}]
  outreachStrategy   String?  @db.Text  // opening angle, connection path

  // Qualification
  qualificationScore String?  // HOT, WARM, COLD, NOT_FIT
  qualificationNotes String?  @db.Text
  lostReason         String?  @db.Text

  // Ownership
  assignedToId       String?
  assignedTo         User?    @relation("LeadOwner", fields: [assignedToId], references: [id], onDelete: SetNull)

  // Links
  existingClientId   String?
  existingClient     Client?  @relation("LeadFromClient", fields: [existingClientId], references: [id])
  convertedToClientId String?
  convertedToClient  Client?  @relation("LeadConverted", fields: [convertedToClientId], references: [id])

  referrals          Referral[]
  discoveryCalls     DiscoveryCall[]

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([source, status])
  @@index([assignedToId])
  @@index([status])
}

enum TalentApplicationStatus {
  SUBMITTED
  AI_SCREENED
  UNDER_REVIEW
  SHORTLISTED
  INTERVIEW_SCHEDULED
  OFFER_EXTENDED
  APPROVED
  HIRED
  REJECTED
  WITHDRAWN
}

enum EngagementType {
  PROJECT
  RETAINER
  SECONDMENT
  FRACTIONAL
  TRANSFORMATION
  TRANSACTION
}

// Deal structure for TRANSFORMATION engagements
enum DealStructure {
  SWEAT
  CAPITAL
  HYBRID
}

// Mandate type for TRANSACTION engagements
enum MandateType {
  SELL_SIDE
  BUY_SIDE
  FUNDRAISE
}

model TalentApplication {
  id String @id @default(cuid())

  // Personal
  firstName   String
  lastName    String
  email       String   @unique
  phone       String?
  linkedinUrl String?
  location    String

  // Professional
  specialty          String
  yearsExperience    Int
  currentRole        String?
  currentOrg         String?
  workAuthorization  String   @default("nigerian_citizen")

  // Track
  track             String   @default("CONSULTANT") // CONSULTANT, INTERN, FELLOWSHIP, SIWES

  // Application
  cvText            String?  @db.Text
  cvFileUrl         String?
  coverLetter       String?  @db.Text
  availableFrom     DateTime?
  engagementTypes   String[] // array of EngagementType values

  // Intern-specific fields
  university        String?
  programme         String?  // Health Admin, Public Health, etc.
  yearOfStudy       String?  // e.g. "300-level", "Final year"
  siwesEligible     Boolean  @default(false)

  // AI Screening
  aiScore           Int?     // 0-100
  aiScoreBreakdown  Json?    // { experience, specialty_fit, leadership, impact, communication }
  aiSummary         String?  @db.Text
  aiStrengths       String[] 
  aiConcerns        String[]
  aiRecommendation  String?  // STRONG_YES, YES, MAYBE, NO

  // Status
  status          TalentApplicationStatus @default(SUBMITTED)
  reviewNotes     String? @db.Text
  reviewedById    String?
  reviewedBy      User?   @relation("ApplicationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt      DateTime?

  // Onboarding link
  convertedToUserId     String?
  assessmentLevel       String  @default("STANDARD") // LIGHT, STANDARD, MAAROVA, FULL

  // Rejection flow
  rejectionSegment      String?  // JUNIOR, WRONG_FIT, WEAK_COMMS, NOT_READY, INTEGRITY_FLAGS
  previousApplicationId String?  // links to original rejected application on reapplication

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Communications CRM back-relations
  communications   Communication[]
  commParticipants CommunicationParticipant[] @relation("CommParticipantApplication")

  @@index([status, createdAt])
  @@index([specialty])
  @@index([aiScore])
}

// ─── Project Delivery Models ───────────────────────────────────────────────────

model EngagementPhase {
