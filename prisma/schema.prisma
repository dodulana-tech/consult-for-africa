generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  CONSULTANT
  ENGAGEMENT_MANAGER
  DIRECTOR
  PARTNER
  ADMIN
  ACADEMY_LEARNER
}

enum TrackPricingType {
  FREE
  PAID
  SCHOLARSHIP
}

enum ConsultantTier {
  ELITE
  EXPERIENCED
  STANDARD
  EMERGING
  INTERN
}

enum AvailabilityStatus {
  AVAILABLE
  PARTIALLY_AVAILABLE
  UNAVAILABLE
  ON_LEAVE
}

enum Currency {
  USD
  NGN
}

enum OwnGigFeeModel {
  PERCENTAGE
  FLAT_MONTHLY
}

enum OwnGigApprovalStatus {
  PENDING
  APPROVED
  NEEDS_CHANGES
  REJECTED
}

enum ClientType {
  PRIVATE_ELITE
  PRIVATE_MIDTIER
  STARTUP
  SME
  GOVERNMENT
  DEVELOPMENT
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  OVERDUE_PAYMENT
  BLACKLISTED
}

enum ServiceType {
  HOSPITAL_OPERATIONS
  TURNAROUND
  EMBEDDED_LEADERSHIP
  CLINICAL_GOVERNANCE
  DIGITAL_HEALTH
  HEALTH_SYSTEMS
  DIASPORA_EXPERTISE
  EM_AS_SERVICE
}

enum EngagementStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  AT_RISK
  COMPLETED
  CANCELLED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AssignmentStatus {
  PENDING_ACCEPTANCE  // Sent to consultant, awaiting their response
  PENDING             // Accepted but not yet started
  ACTIVE
  PAUSED
  COMPLETED
  TERMINATED
  DECLINED            // Consultant declined the assignment
}

enum RateType {
  HOURLY
  DAILY
  MONTHLY
  FIXED_PROJECT
  FIXED_DELIVERABLE
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  DELAYED
  SKIPPED
}

enum DeliverableStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  NEEDS_REVISION
  APPROVED
  DELIVERED_TO_CLIENT
}

enum TimeEntryStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum InvoiceStatus {
  DRAFT
  PENDING_APPROVAL
  SENT
  VIEWED
  PARTIALLY_PAID
  PAID
  OVERDUE
  DISPUTED
  WRITTEN_OFF
  CANCELLED
}

enum InvoiceType {
  STANDARD
  PROFORMA
  CREDIT_NOTE
  DEBIT_NOTE
  MOBILIZATION
  MILESTONE
  RETAINER
  FINAL_SETTLEMENT
}

enum FeeStructure {
  FIXED_FEE
  TIME_AND_MATERIALS
  RETAINER
  SUCCESS_FEE
  MILESTONE_BASED
  HYBRID
}

enum BillingCycle {
  ONE_TIME
  MONTHLY
  QUARTERLY
  ON_MILESTONE
  ON_COMPLETION
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
  REVERSED
}

enum UpdateType {
  GENERAL
  MILESTONE_COMPLETED
  ISSUE
  CLIENT_FEEDBACK
  TEAM_CHANGE
  WORK_STREAM_UPDATE
}

enum PhaseStatus {
  PENDING
  ACTIVE
  COMPLETED
  SKIPPED
}

enum RiskSeverity {
  GREEN
  AMBER
  RED
}

enum RiskItemStatus {
  OPEN
  MITIGATING
  RESOLVED
  ACCEPTED
}

enum PaymentMilestoneStatus {
  PENDING
  INVOICED
  PAID
  OVERDUE
}

enum InteractionType {
  CALL
  MEETING
  EMAIL
  WORKSHOP
  SITE_VISIT
  REPORT_DELIVERY
}

enum InteractionSentiment {
  POSITIVE
  NEUTRAL
  CONCERNED
  NEGATIVE
}

enum CommentAuthorType {
  INTERNAL
  CLIENT
}

enum DeliverableReviewStage {
  DRAFT
  PEER_REVIEW
  INTERNAL_QA
  CLIENT_REVIEW
  APPROVED
  DELIVERED
}

enum KnowledgeAssetType {
  INSIGHT
  FRAMEWORK
  TEMPLATE
  CASE_STUDY
  LESSON_LEARNED
  TOOL
  GUIDE
}

// ─── Core Models ──────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String?
  role         UserRole @default(CONSULTANT)
  avatarUrl    String?
  notificationPreferences Json @default("{}")
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  consultantProfile      ConsultantProfile?
  engagementManagerProfile EngagementManagerProfile?
  managedEngagements     Engagement[]      @relation("EngagementEM")
  assignments            Assignment[]
  timeEntries            TimeEntry[]
  sentMessages           Message[]
  engagementUpdates      EngagementUpdate[]
  reviewedApplications   TalentApplication[] @relation("ApplicationReviewer")
  referrals              Referral[]
  trainingEnrollments    TrainingEnrollment[]
  auditLogs              AuditLog[]
  staffingRequests       StaffingRequest[]    @relation("StaffingRequestCreator")
  staffingExpressions    StaffingExpression[] @relation("StaffingExpressions")
  proposals              Proposal[]
  onboarding             ConsultantOnboarding?
  consultantAssessments  ConsultantAssessment[]
  discoveryCalls         DiscoveryCall[]
  ownedLeads             Lead[]         @relation("LeadOwner")
  internRotations        InternRotation[] @relation("InternRotations")
  supervisedRotations    InternRotation[] @relation("SupervisedRotations")
  internEvaluations      InternEvaluation[] @relation("InternEvaluations")
  outreachCampaigns      OutreachCampaign[] @relation("CampaignCreator")
  organizedMeetings      Meeting[]          @relation("MeetingOrganizer")
  meetingParticipations  MeetingParticipant[] @relation("MeetingParticipants")
  consultantNdas         Nda[]              @relation("ConsultantNdas")
  createdNdas            Nda[]              @relation("NdaCreator")
  invoicesApproved       Invoice[]          @relation("InvoiceApprover")
  paymentsConfirmed      Payment[]          @relation("PaymentConfirmer")
  creditNotesCreated     CreditNote[]       @relation("CreditNoteCreator")
  ownGigEngagements      Engagement[]       @relation("OwnGigOwner")
  ownGigReviews          Engagement[]       @relation("OwnGigReviewer")
  ownGigFees             OwnGigPlatformFee[] @relation("OwnGigFeeConsultant")
  trackPurchases         TrackPurchase[]
  salesAgentProfile      SalesAgent?
  sourceApplicationId    String?            // TalentApplication ID that created this ACADEMY_LEARNER account

  // Communications CRM back-relations
  commsAsSubject         Communication[]            @relation("CommSubjectConsultant")
  commsLogged            Communication[]            @relation("LoggedComms")
  commsNextActions       Communication[]            @relation("CommNextAction")
  commsAsParticipant     CommunicationParticipant[] @relation("CommParticipantConsultant")
  commEventsActed        CommunicationEvent[]       @relation("CommEventActor")
  bulkCommsCreated       BulkCommunication[]        @relation("CreatedBulkComms")
  commTemplatesCreated   CommunicationTemplate[]    @relation("CreatedTemplates")
}

model ConsultantProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title           String
  bio             String    @db.Text
  location        String
  isDiaspora      Boolean   @default(false)
  expertiseAreas       String[]   // ServiceType values (project-level matching)
  specialties          String[]   // ConsultantSpecialty values (granular skills)
  specialtyCategory    String?    // Primary specialty category
  primarySpecialty     String?    // Primary ConsultantSpecialty value
  yearsExperience Int
  tier            ConsultantTier     @default(STANDARD)
  hourlyRateUSD   Decimal?  @db.Decimal(10, 2)
  monthlyRateNGN  Decimal?  @db.Decimal(12, 2)
  availabilityStatus AvailabilityStatus @default(AVAILABLE)
  hoursPerWeek    Int?
  weeklyCapacityHours Int   @default(40)  // max hours/week consultant is available
  maxUtilization  Int       @default(85)  // utilization % threshold before warning
  interests       String[]              // topics consultant wants to work on
  averageRating   Decimal?  @db.Decimal(3, 2)
  totalProjects   Int       @default(0)
  ownGigOverride  Json?                       // Admin override for own gig access: { enabled, maxConcurrent, maxBudgetNGN, maxBudgetUSD, minFeePct, reason, grantedBy, grantedAt }
  bankName        String?
  accountNumber   String?
  accountName     String?
  swiftCode       String?
  currency        Currency  @default(NGN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ratings ConsultantRating[]
}

model EngagementManagerProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title           String
  bio             String @db.Text
  yearsExperience Int
  currentProjects Int    @default(0)
  maxProjects     Int    @default(5)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client {
  id             String       @id @default(cuid())
  name           String
  type           ClientType
  primaryContact String
  email          String
  phone          String
  address        String
  paymentTerms   Int          @default(30)
  currency       Currency     @default(NGN)
  status         ClientStatus @default(ACTIVE)
  creditScore    Int?         @default(3)
  notes          String?      @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  engagements       Engagement[]
  invoices          Invoice[]
  contacts          ClientContact[]
  expansionRequests ClientExpansionRequest[]
  proposals         Proposal[]
  discoveryCalls    DiscoveryCall[]
  leadsFrom         Lead[]         @relation("LeadFromClient")
  leadsConverted    Lead[]         @relation("LeadConverted")
  ndas              Nda[]
  creditNotes       CreditNote[]
  agentOpportunities AgentOpportunity[]

  // Communications CRM back-relations
  communications     Communication[]
  commParticipants   CommunicationParticipant[] @relation("CommParticipantClient")

  @@index([type, status])
}

model Engagement {
  id                  String           @id @default(cuid())
  clientId            String
  client              Client           @relation(fields: [clientId], references: [id])
  engagementManagerId String?
  engagementManager   User?            @relation("EngagementEM", fields: [engagementManagerId], references: [id], onDelete: SetNull)

  // Common fields
  name           String
  description    String           @db.Text
  serviceType    ServiceType
  engagementType EngagementType   @default(PROJECT)
  startDate      DateTime
  endDate        DateTime?
  status         EngagementStatus @default(PLANNING)
  budgetAmount   Decimal          @db.Decimal(14, 2)
  budgetCurrency Currency         @default(NGN)
  actualSpent    Decimal          @default(0) @db.Decimal(14, 2)
  healthScore              Int?          @default(5)
  riskLevel                RiskLevel     @default(LOW)
  notes                    String?       @db.Text
  budgetSensitivity        String?       // PREMIUM, STANDARD, VALUE, BUDGET
  consultantTierMin        String?       // INTERN, EMERGING, STANDARD, EXPERIENCED, ELITE
  consultantTierMax        String?       // INTERN, EMERGING, STANDARD, EXPERIENCED, ELITE
  internEligible           Boolean       @default(false)
  pricingNotes             String?       @db.Text
  clientSatisfactionScore  Int?
  methodology              String?
  methodologyId            String?
  methodologyTemplate      MethodologyTemplate? @relation("EngagementMethodology", fields: [methodologyId], references: [id])
  engagementCode           String?       @unique // C4A-YYYY-NNN format
  feeStructure             FeeStructure?

  // RETAINER fields
  retainerMonthlyFee       Decimal?      @db.Decimal(14, 2)
  retainerHoursPool        Int?          // monthly hours included
  retainerAutoRenew        Boolean?
  retainerNoticePeriodDays Int?

  // SECONDMENT fields
  secondeeId               String?       // User ID of the seconded individual
  secondeeClientLineManager String?
  secondeeRecallClauseDays  Int?
  secondeeMaarovaProfileUrl String?
  secondeeMonthlyFee       Decimal?      @db.Decimal(14, 2)

  // FRACTIONAL fields
  fractionalPlacedName     String?
  fractionalRoleTitle      String?
  fractionalCommissionPct  Decimal?      @db.Decimal(5, 2)
  fractionalArrangementFee Decimal?      @db.Decimal(14, 2) // monthly
  fractionalPlacementDate  DateTime?
  fractionalConvertedToPermanent Boolean?

  // TRANSFORMATION fields
  transformHospitalId      String?
  transformEquityPct       Decimal?      @db.Decimal(5, 2)
  transformDealStructure   DealStructure?
  transformEntryValuation  Decimal?      @db.Decimal(14, 2)
  transformBoardSeat       Boolean?
  transformStepInTrigger   Int?          // consecutive months of missed KPIs
  transformExitMonths      Int?          // exit timeline in months from start

  // TRANSACTION fields
  transactionMandateType   MandateType?
  transactionTargetCompany String?
  transactionDealSize      Decimal?      @db.Decimal(14, 2)
  transactionSuccessFeePct Decimal?      @db.Decimal(5, 2)
  transactionUpfrontRetainer Decimal?    @db.Decimal(14, 2)
  transactionCloseDate     DateTime?
  transactionSuccessFeeAmount Decimal?   @db.Decimal(14, 2) // calculated on close

  // OWN GIG fields
  isOwnGig                Boolean       @default(false)
  ownGigOwnerId           String?
  ownGigOwner             User?         @relation("OwnGigOwner", fields: [ownGigOwnerId], references: [id], onDelete: SetNull)
  ownGigFeeModel          OwnGigFeeModel?
  ownGigFeePct            Decimal?      @db.Decimal(5, 2)  // 10-15% for PERCENTAGE model
  ownGigFlatMonthlyFee    Decimal?      @db.Decimal(14, 2) // for FLAT_MONTHLY model
  ownGigApprovalStatus    OwnGigApprovalStatus?
  ownGigApprovalNote      String?       @db.Text
  ownGigSubmittedAt       DateTime?
  ownGigReviewedAt        DateTime?
  ownGigReviewedById      String?
  ownGigReviewedBy        User?         @relation("OwnGigReviewer", fields: [ownGigReviewedById], references: [id], onDelete: SetNull)
  ownGigConflictFlag      Boolean       @default(false)
  ownGigConflictNote      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownGigFees        OwnGigPlatformFee[]
  assignments       Assignment[]
  milestones        Milestone[]
  deliverables      Deliverable[]
  invoices          Invoice[]
  messages          Message[]
  updates           EngagementUpdate[]
  phases            EngagementPhase[]
  risks             RiskItem[]
  paymentMilestones PaymentMilestone[]
  interactions      ClientInteraction[]
  meetings          Meeting[]
  ndas              Nda[]
  impactMetrics     EngagementImpactMetric[]
  knowledgeAssets   KnowledgeAsset[]
  frameworks        EngagementFramework[]
  staffingRequests       StaffingRequest[]
  tracks                 EngagementTrack[]
  satisfactionPulses     ClientSatisfactionPulse[]
  recommendations        ClientRecommendation[]
  internRotations        InternRotation[]
  billingSchedules       BillingSchedule[]
  creditNotes            CreditNote[]
  agentOpportunities     AgentOpportunity[]

  @@map("Project")
  @@index([clientId])
  @@index([engagementManagerId])
  @@index([status])
  @@index([engagementType])
  @@index([isOwnGig, ownGigOwnerId])
}

model OwnGigPlatformFee {
  id              String         @id @default(cuid())
  engagementId    String
  engagement      Engagement     @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  consultantId    String
  consultant      User           @relation("OwnGigFeeConsultant", fields: [consultantId], references: [id], onDelete: Cascade)

  periodStart     DateTime
  periodEnd       DateTime
  feeModel        OwnGigFeeModel
  projectValue    Decimal?       @db.Decimal(14, 2)
  feeAmount       Decimal        @db.Decimal(14, 2)
  currency        Currency       @default(NGN)
  status          String         @default("PENDING") // PENDING, INVOICED, PAID

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([engagementId])
  @@index([consultantId])
  @@index([status])
}

// ─── Engagement Tracks (workstreams) ──────────────────────────────────────────

model EngagementTrack {
  id           String     @id @default(cuid())
  engagementId String     @map("projectId")
  engagement   Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  name         String
  description  String?             @db.Text
  order        Int                 @default(0)
  status       EngagementTrackStatus @default(OPEN)
  startDate    DateTime?
  endDate      DateTime?
  budgetAmount Decimal?            @db.Decimal(14, 2)
  budgetCurrency Currency?

  assignments      Assignment[]
  deliverables     Deliverable[]
  timeEntries      TimeEntry[]
  staffingRequests StaffingRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([engagementId])
}

enum EngagementTrackStatus {
  OPEN
  ACTIVE
  PAUSED
  COMPLETED
}

// ─── Assignments ─────────────────────────────────────────────────────────────

model Assignment {
  id           String           @id @default(cuid())
  engagementId String           @map("projectId")
  engagement   Engagement       @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  consultantId String
  consultant   User             @relation(fields: [consultantId], references: [id], onDelete: Cascade)

  // Track assignment (optional - null means project-level floater)
  trackId      String?
  track        EngagementTrack? @relation(fields: [trackId], references: [id])
  trackRole    String?                  // "Track Lead", "Support", "Specialist", "Analyst", "Intern"

  role             String
  responsibilities String         @db.Text
  startDate        DateTime
  endDate          DateTime?
  status           AssignmentStatus @default(PENDING_ACCEPTANCE)

  // Allocation
  allocationPct    Int              @default(100) // 0-100, percentage of FTE

  // What C4A pays consultant (cost rate)
  rateAmount       Decimal          @db.Decimal(10, 2)
  rateCurrency     Currency
  rateType         RateType

  // What client is billed (bill rate, optional - derived from BillingSchedule if not set)
  billRate         Decimal?         @db.Decimal(10, 2)
  billCurrency     Currency?

  isBillable       Boolean          @default(true) // false for interns/shadows

  estimatedHours   Int?
  estimatedDays    Int?                  // for DAILY rate type
  estimatedHoursPerWeek Int?             // weekly commitment for capacity tracking
  respondedAt      DateTime?            // when consultant accepted/declined
  declineReason    String?   @db.Text   // reason if declined
  capacityAtAssignment Int?             // snapshot of utilization % when assigned

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  timeEntries  TimeEntry[]
  deliverables Deliverable[]

  @@index([engagementId], map: "Assignment_projectId_status_idx")
  @@index([consultantId])
  @@index([trackId])
}

model Milestone {
  id             String          @id @default(cuid())
  engagementId   String          @map("projectId")
  engagement     Engagement      @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  name           String
  description    String          @db.Text
  dueDate        DateTime
  status         MilestoneStatus @default(PENDING)
  completionDate DateTime?
  order          Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deliverables Deliverable[]
}

model Deliverable {
  id           String            @id @default(cuid())
  engagementId String            @map("projectId")
  engagement   Engagement        @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  milestoneId  String?
  milestone    Milestone?        @relation(fields: [milestoneId], references: [id])
  assignmentId String?
  assignment   Assignment?       @relation(fields: [assignmentId], references: [id])
  trackId      String?
  track        EngagementTrack?  @relation(fields: [trackId], references: [id])

  name          String
  description   String                 @db.Text
  fileUrl       String?
  status        DeliverableStatus      @default(DRAFT)
  reviewStage   DeliverableReviewStage @default(DRAFT)
  clientVisible Boolean                @default(false)
  dueDate       DateTime?
  submittedAt   DateTime?
  reviewedAt    DateTime?
  approvedAt    DateTime?
  reviewScore   Int?
  reviewNotes   String?                @db.Text
  reviewedById  String?
  microFeedback String?                // quick EM reaction: "great work", "well structured", etc.
  version       Int                    @default(1)

  // Deliverable-based pricing (for FIXED_DELIVERABLE rate type)
  fee           Decimal?               @db.Decimal(12, 2)
  feeCurrency   Currency?
  feePaidAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  versions     DeliverableVersion[]
  comments     DeliverableComment[]

  @@index([engagementId], map: "Deliverable_projectId_status_idx")
  @@index([assignmentId])
  @@index([trackId])
}

model TimeEntry {
  id           String          @id @default(cuid())
  assignmentId String
  assignment   Assignment      @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  consultantId String
  consultant   User            @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  trackId      String?
  track        EngagementTrack? @relation(fields: [trackId], references: [id])

  date           DateTime
  hours          Decimal         @db.Decimal(5, 2)
  hoursWorked    Decimal?        @db.Decimal(5, 2)   // user-entered hours (HOURLY)
  description    String          @db.Text
  status         TimeEntryStatus @default(PENDING)
  approvedById   String?
  approvedAt     DateTime?
  billableAmount Decimal?        @db.Decimal(10, 2)
  currency       Currency
  periodMonth    Int?            // for MONTHLY rate type
  periodYear     Int?            // for MONTHLY rate type
  isForBilling   Boolean         @default(true)
  rejectionReason String?        @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([consultantId])
  @@index([assignmentId, status])
  @@index([trackId])
}

model Invoice {
  id              String        @id @default(cuid())
  clientId        String
  client          Client        @relation(fields: [clientId], references: [id])
  engagementId    String?       @map("projectId")
  engagement      Engagement?   @relation(fields: [engagementId], references: [id])

  invoiceNumber   String        @unique
  invoiceType     InvoiceType   @default(STANDARD)
  subtotal        Decimal       @db.Decimal(14, 2)
  tax             Decimal       @default(0) @db.Decimal(14, 2)
  whtAmount       Decimal       @default(0) @db.Decimal(14, 2)  // withholding tax deducted at source
  discountAmount  Decimal       @default(0) @db.Decimal(14, 2)
  total           Decimal       @db.Decimal(14, 2)
  paidAmount      Decimal       @default(0) @db.Decimal(14, 2)  // running total of payments
  balanceDue      Decimal       @default(0) @db.Decimal(14, 2)
  currency        Currency      @default(NGN)
  status          InvoiceStatus @default(DRAFT)
  issuedDate      DateTime?
  dueDate         DateTime?
  paidDate        DateTime?
  viewedAt        DateTime?
  paymentMethod   String?       // legacy, prefer Payment records
  paymentReference String?      // legacy, prefer Payment records
  lineItems       Json          // legacy JSON, prefer InvoiceLineItem records

  // Approval workflow
  approvedById    String?
  approvedBy      User?         @relation("InvoiceApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt      DateTime?

  // Billing context
  billingScheduleId String?
  billingSchedule   BillingSchedule? @relation(fields: [billingScheduleId], references: [id])
  billingPeriodStart DateTime?
  billingPeriodEnd   DateTime?

  // Notes
  notes          String?       @db.Text // internal
  clientNotes    String?       @db.Text // shown on invoice
  bankDetails    Json?         // C4A bank details to display

  // Partner firm invoicing
  partnerFirmId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  lineItemRecords InvoiceLineItem[]
  payments        Payment[]
  reminders       InvoiceReminder[]
  creditNotesIssued CreditNote[]   @relation("CreditNoteOriginal")
  creditNotesApplied CreditNote[]  @relation("CreditNoteApplied")
  paymentMilestones  PaymentMilestone[]

  @@index([clientId])
  @@index([engagementId], map: "Invoice_projectId_idx")
  @@index([status])
  @@index([invoiceType])
  @@index([dueDate])
}

model EngagementUpdate {
  id             String     @id @default(cuid())
  engagementId   String     @map("projectId")
  engagement     Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  content        String     @db.Text
  type           UpdateType @default(GENERAL)
  clientVisible  Boolean    @default(false)
  createdById    String?
  createdBy      User?      @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime   @default(now())

  @@map("ProjectUpdate")
  @@index([engagementId], map: "ProjectUpdate_projectId_createdAt_idx")
}

model Message {
  id          String      @id @default(cuid())
  engagementId String?    @map("projectId")
  engagement   Engagement? @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  senderId    String?
  sender      User?    @relation(fields: [senderId], references: [id], onDelete: SetNull)
  content     String   @db.Text
  attachments String[]
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([engagementId], map: "Message_projectId_idx")
  @@index([senderId])
}

model ConsultantRating {
  id                String            @id @default(cuid())
  consultantId      String
