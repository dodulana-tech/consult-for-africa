  @@index([debriefId])
  @@index([assetId])
}

model AssetDownloadLog {
  id           String   @id @default(cuid())
  assetId      String
  engagementId String?
  downloadedBy String
  createdAt    DateTime @default(now())

  @@index([assetId])
  @@index([engagementId])
}

