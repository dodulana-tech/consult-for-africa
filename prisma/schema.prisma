  user        MaarovaUser                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dimension   String
  title       String
  description String                          @db.Text
  targetDate  DateTime?
  status      MaarovaDevelopmentGoalStatus     @default(NOT_STARTED)
