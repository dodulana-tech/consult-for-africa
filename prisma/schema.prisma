  SCENARIO_RESPONSE
  LIKERT_5
  LIKERT_7
  FREQUENCY_SCALE
  FREE_TEXT
}

model MaarovaOrganisation {
  id             String   @id @default(cuid())
  name           String
  type           String
  country        String   @default("Nigeria")
  city           String?
  contactName    String
  contactEmail   String
  contactPhone   String?
  stream         MaarovaStream
  maxAssessments Int      @default(1)
  usedAssessments Int     @default(0)
  isActive       Boolean  @default(true)
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users   MaarovaUser[]
  coaches MaarovaCoach[]

  @@index([stream, isActive])
}

model MaarovaUser {
  id                 String   @id @default(cuid())
  organisationId     String
  organisation       MaarovaOrganisation @relation(fields: [organisationId], references: [id])
  email              String   @unique
  name               String
  passwordHash       String?
  title              String?
  department         String?
  yearsInRole        Int?
  yearsInHealthcare  Int?
  clinicalBackground String?
  isPortalEnabled    Boolean  @default(false)
  lastLoginAt        DateTime?
  invitedAt          DateTime?
  resetToken         String?
  resetTokenExpiry   DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  sessions           MaarovaAssessmentSession[]
  reports            MaarovaReport[]
  coachingMatches    MaarovaCoachingMatch[]
  developmentGoals   MaarovaDevelopmentGoal[]
  raterInvites       Maarova360RaterInvite[]
  threeSixtyRequests Maarova360Request[]

  @@index([organisationId])
}

model MaarovaCoach {
  id              String   @id @default(cuid())
  organisationId  String?
  organisation    MaarovaOrganisation? @relation(fields: [organisationId], references: [id])
  name            String
  email           String   @unique
  title           String
  bio             String   @db.Text
  specialisms     String[]
  certifications  String[]
  country         String
  city            String?
  yearsExperience Int
  maxClients      Int      @default(8)
  activeClients   Int      @default(0)
  isActive        Boolean  @default(true)
  avatarUrl       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  matches MaarovaCoachingMatch[]

  @@index([isActive])
}

model MaarovaModule {
  id               String            @id @default(cuid())
  type             MaarovaModuleType
  name             String
  slug             String            @unique
  description      String            @db.Text
  order            Int
  estimatedMinutes Int               @default(10)
  isActive         Boolean           @default(true)
  scoringConfig    Json
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  questionGroups  MaarovaQuestionGroup[]
  moduleResponses MaarovaModuleResponse[]

  @@index([type])
  @@index([order])
}

model MaarovaQuestionGroup {
  id          String        @id @default(cuid())
  moduleId    String
  module      MaarovaModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  name        String?
  description String?       @db.Text
  order       Int
  context     String?       @db.Text
  createdAt   DateTime      @default(now())

  questions MaarovaQuestion[]

  @@index([moduleId, order])
}

model MaarovaQuestion {
  id           String                @id @default(cuid())
  groupId      String
  group        MaarovaQuestionGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  format       MaarovaQuestionFormat
  text         String                @db.Text
  options      Json
  dimension    String?
  subDimension String?
  isReversed   Boolean               @default(false)
  weight       Decimal               @default(1) @db.Decimal(4, 2)
  order        Int
  isActive     Boolean               @default(true)
  createdAt    DateTime              @default(now())

  responses MaarovaItemResponse[]

  @@index([groupId, order])
}

model MaarovaAssessmentSession {
  id               String                  @id @default(cuid())
  userId           String
  user             MaarovaUser             @relation(fields: [userId], references: [id], onDelete: Cascade)
  status           MaarovaAssessmentStatus @default(NOT_STARTED)
  sessionType      String                  @default("full")
  stream           MaarovaStream
  startedAt        DateTime?
  completedAt      DateTime?
  expiresAt        DateTime
  ipAddress        String?
  userAgent        String?
  totalTimeMinutes Int?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  moduleResponses MaarovaModuleResponse[]
  report          MaarovaReport?

  @@index([userId, status])
  @@index([status, expiresAt])
}

model MaarovaModuleResponse {
  id               String                   @id @default(cuid())
  sessionId        String
  session          MaarovaAssessmentSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  moduleId         String
  module           MaarovaModule             @relation(fields: [moduleId], references: [id])
  status           MaarovaAssessmentStatus   @default(NOT_STARTED)
  startedAt        DateTime?
  completedAt      DateTime?
  timeSpentSeconds Int?
  rawScores        Json?
  scaledScores     Json?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  itemResponses MaarovaItemResponse[]

  @@unique([sessionId, moduleId])
  @@index([sessionId])
  @@index([moduleId])
}

model MaarovaItemResponse {
  id               String                @id @default(cuid())
  moduleResponseId String
  moduleResponse   MaarovaModuleResponse @relation(fields: [moduleResponseId], references: [id], onDelete: Cascade)
  questionId       String
  question         MaarovaQuestion       @relation(fields: [questionId], references: [id])
  answer           Json
  responseTimeMs   Int?
  answeredAt       DateTime              @default(now())

  @@unique([moduleResponseId, questionId])
  @@index([moduleResponseId])
}

model Maarova360Request {
  id        String      @id @default(cuid())
  subjectId String
  subject   MaarovaUser @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  sessionId String?
  status    String      @default("COLLECTING")
  minRaters Int         @default(5)
  deadline  DateTime
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  invites Maarova360RaterInvite[]

  @@index([subjectId])
}

model Maarova360RaterInvite {
  id          String           @id @default(cuid())
  requestId   String
  request     Maarova360Request @relation(fields: [requestId], references: [id], onDelete: Cascade)
  raterId     String?
  rater       MaarovaUser?     @relation(fields: [raterId], references: [id])
  raterEmail  String
  raterName   String
  role        MaarovaRaterRole
  token       String           @unique
  status      String           @default("INVITED")
  completedAt DateTime?
  responses   Json?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([requestId])
  @@index([token])
}

model MaarovaReport {
  id        String                   @id @default(cuid())
  sessionId String                   @unique
  session   MaarovaAssessmentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId    String
  user      MaarovaUser              @relation(fields: [userId], references: [id])
  status    MaarovaReportStatus      @default(GENERATING)

  overallScore         Int?
  dimensionScores      Json?
  radarChartData       Json?
  benchmarkComparisons Json?

  executiveSummary    String?  @db.Text
  strengthsAnalysis   String?  @db.Text
  developmentAreas    String?  @db.Text
  nextLeadershipEdge  String?  @db.Text
  blindSpotAnalysis   String?  @db.Text
  coachingPriorities  Json?
  leadershipArchetype String?
  archetypeNarrative  String?  @db.Text
  signatureStrengths  Json?

  fullReportContent Json?

  generatedAt DateTime?
  deliveredAt DateTime?
  pdfUrl      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model MaarovaCoachingMatch {
