  engagementId      String            @map("projectId")
  technicalQuality  Int
  communication     Int
  timeliness        Int
  professionalism   Int
  overallRating     Int
  feedback          String?           @db.Text
  ratedById         String
  createdAt         DateTime          @default(now())

  @@index([consultantId])
  @@index([engagementId], map: "ConsultantRating_projectId_idx")
}

model ConsultantMatchScore {
  id           String   @id @default(cuid())
  engagementId String   @map("projectId")
  consultantId String

  matchScore        Int
  rankPosition      Int

  expertiseScore    Decimal  @db.Decimal(4, 3)
  performanceScore  Decimal  @db.Decimal(4, 3)
  availabilityScore Decimal  @db.Decimal(4, 3)
  costScore         Decimal  @db.Decimal(4, 3)
  fitScore          Decimal  @db.Decimal(4, 3)

