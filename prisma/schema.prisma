model PhaseGate {
  id          String          @id @default(cuid())
  phaseId     String
  phase       EngagementPhase @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  name        String
  passed      Boolean      @default(false)
  passedAt    DateTime?
